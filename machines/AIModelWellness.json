{
  "version": "1.0.0",
  "machine": {
    "id": "ai-model-wellness",
    "name": "AI Model Wellness Monitor",
    "description": "Monitors AI model serving health — tracks inference error rate, latency SLO compliance, model accuracy drift, and memory leak indicators to detect model degradation before user impact.",
    "arbiterRule": "PASSTHROUGH",
    "matchAlgorithm": "gte",
    "perceptualMapping": {
      "input": {
        "offset": 272,
        "length": 4
      },
      "output": {
        "offset": 304,
        "length": 6
      },
      "bitsPerElement": 8
    },
    "metadata": {
      "category": "ai-services",
      "domain": "AI Infrastructure — Model Serving Health",
      "tags": [
        "ai-infrastructure",
        "ai-infrastructure-model-serving-health",
        "ai-model-wellness-monitor",
        "ai-services",
        "ai-trigger",
        "aimodel-wellness",
        "ces-sequences",
        "ces-sequences-2",
        "drift",
        "inference",
        "input-sequences",
        "input-sequences-3",
        "model-serving",
        "model-serving-health",
        "slo",
        "startup-loadable"
      ],
      "inputDimensions": [
        {
          "index": 0,
          "name": "inference_error_rate",
          "description": "0=no errors, 1=complete failure (all requests erroring)"
        },
        {
          "index": 1,
          "name": "latency_slo_ratio",
          "description": "0=at or below SLO, 1=severely exceeding SLO (e.g., 10x target latency)"
        },
        {
          "index": 2,
          "name": "accuracy_drift_score",
          "description": "0=no concept drift, 1=severe model staleness/distribution shift"
        },
        {
          "index": 3,
          "name": "memory_leak_score",
          "description": "0=stable memory, 1=rapid memory growth (leak indicator)"
        }
      ],
      "outputDimensions": [
        {
          "index": 0,
          "name": "STATUS_HEALTHY"
        },
        {
          "index": 1,
          "name": "STATUS_DEGRADED"
        },
        {
          "index": 2,
          "name": "STATUS_CRITICAL"
        },
        {
          "index": 3,
          "name": "STATUS_FAILED"
        },
        {
          "index": 4,
          "name": "ACT_REFRESH_MODEL_WEIGHTS"
        },
        {
          "index": 5,
          "name": "ACT_FAILOVER_TO_BACKUP"
        }
      ],
      "tagging": {
        "schemaVersion": "1.0.0",
        "managedBy": "scripts/manage_machine_tags.mjs",
        "primaryDomain": "ai-services",
