        "name": "Latency SLO Breach",
        "description": "Latency spikes while error rate and accuracy remain acceptable — isolated infrastructure issue",
        "metadata": {
          "expectedOutputs": 1,
          "scenario": "KV cache exhaustion in transformer model causing inference latency spike"
        },
        "vectors": [
          [
            0.06,
            0.14,
            0.1,
