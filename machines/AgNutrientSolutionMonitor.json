    "metadata": {
      "category": "agriculture",
      "domain": "Agriculture \u2014 Nutrient Management / Hydroponics",
      "author": "Reality Engine",
      "outputSpace": "4D binary at [28:32]: [1,0,0,0]=PH_ALERT, [0,1,0,0]=EC_ALERT, [0,0,1,0]=DEFICIENCY_ALERT, [0,0,0,1]=SOLUTION_OK",
      "tags": [
        "ag-nutrient-solution-monitor",
