{
  "version": "1.0.0",
  "machine": {
    "name": "Home Social Isolation Monitor",
    "description": "Integration machine that reads combined output signals from the Home Medication Cost Barrier Monitor [2011:2015] and the Home Transportation Barrier Monitor [2015:2019] to detect social isolation driven by access barriers. For low- and medium-income adults managing chronic conditions at home, the combination of medication cost barriers and transportation failures systematically restricts social participation, community connection, and human contact — accelerating depression, cognitive decline, and self-neglect. Output at [2035:2039] is available to downstream care coordination systems.",
    "metadata": {
      "category": "health-personal",
      "domain": "Home Health — Social Isolation / Access Barriers",
      "author": "Reality Engine",
      "outputSpace": "4D binary at [2035:2039]: [1,0,0,0]=SEVERE_ISOLATION, [0,1,0,0]=SOCIAL_WITHDRAWAL, [0,0,1,0]=ISOLATION_RISK, [0,0,0,1]=SOCIALLY_CONNECTED",
      "tags": [
        "access-barriers",
        "ces-sequences",
        "ces-sequences-3",
        "elder-care",
        "health-personal",
        "home-health",
        "home-health-social-isolation-access-barriers",
        "home-social-isolation-monitor",
        "input-sequences",
        "input-sequences-1",
        "kleene-plus",
        "low-income",
        "medication",
        "social-isolation",
        "startup-loadable",
        "transportation"
      ],
      "sequenceCount": 3,
      "populationFocus": "Home-bound adults managing chronic illness; elderly patients without transportation; low-income adults in medication or transport deserts",
      "sensorNormalization": {
        "medication_barrier_signal_norm": "0.0=[1,0,0,0] ADHERENCE_CRISIS from MedCostBarrier (bit 358), 0.5=[0,1,0,0] COST_BARRIER_ACTIVE (bit 359), 1.0=[0,0,0,1] MEDICATION_MANAGED (bit 361)",
        "transport_barrier_signal_norm": "0.0=[1,0,0,0] CRITICAL_ACCESS_FAILURE from Transportation (bit 362), 0.5=[0,0,1,0] TRANSIT_DEPENDENT_RISK (bit 364), 1.0=[0,0,0,1] TRANSPORTATION_ADEQUATE (bit 365)",
        "social_contact_norm": "0.0=zero social contact; not leaving home; no calls; no visitors in >2 weeks, 0.5=minimal contact (one or two interactions per week; phone only), 1.0=regular social contact; community participation",
        "self_care_norm": "0.0=self-neglect evident (nutrition, hygiene, medication all failing), 0.5=managing core self-care with effort; some slippage, 1.0=adequate self-care maintained independently"
      },
      "upstreamMachines": [
        "HomeMedicationCostBarrierMonitor (output [2011:2015])",
        "HomeTransportationBarrierMonitor (output [2015:2019])"
      ],
