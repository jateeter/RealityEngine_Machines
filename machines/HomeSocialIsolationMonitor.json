            "sequenceId": "social-isolation-risk",
            "outputMatches": [
              0,
              0,
              1,
              0
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "ISOLATION_RISK: converging access barriers approaching isolation threshold at [2035:2039]"
          },
          {
            "sequenceId": "social-connected-ok",
            "outputMatches": [
              0,
              0,
              0,
              1
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "SOCIALLY_CONNECTED: access barriers resolved; social participation maintained at [2035:2039]"
          }
        ]
      }
    },
    "arbiterRule": "PASSTHROUGH",
