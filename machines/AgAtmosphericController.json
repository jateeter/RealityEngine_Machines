    "sequences": [
      {
        "id": "ag-atmos-co2-depletion",
        "name": "CO2 Depletion: ENRICHED+ → DECLINING → LOW → DEPLETED → CO2_INJECT",
        "metadata": {
          "description": "Tracks CO2 depletion as photosynthesis consumes enriched atmosphere during peak light periods. The ENRICHED+ initial state ensures CO2 injection is only triggered after confirmed enriched conditions — preventing false triggers during dark periods.",
          "path": "ENRICHED+ → DECLINING → LOW → DEPLETED → output[1,0,0,0]",
          "output": "[1,0,0,0] (CO2_INJECT)"
        },
        "vectors": [
          {
            "id": "ag-atm-co2-enriched",
            "elements": [
              {
                "value": 0.62,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.45,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "ENRICHED",
              "description": "ENRICHED+ — CO2 above ambient (>500 ppm); system has been actively enriched. isInitial A*A = A+: confirms enriched baseline before tracking depletion.",
              "co2_range": "0.55–0.72 (600–900 ppm enriched)"
            },
            "nextVectorIds": [
              "ag-atm-co2-enriched",
              "ag-atm-co2-declining"
            ]
          },
          {
            "id": "ag-atm-co2-declining",
            "elements": [
              {
                "value": 0.42,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.45,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "DECLINING",
              "description": "DECLINING — CO2 falling below enriched threshold as photosynthesis consumes it.",
              "co2_range": "0.35–0.52 (400–600 ppm, approaching ambient)"
            },
            "nextVectorIds": [
              "ag-atm-co2-low"
            ]
          },
          {
            "id": "ag-atm-co2-low",
            "elements": [
              {
                "value": 0.25,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.45,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "LOW",
              "description": "LOW CO2 — below ambient 400 ppm; photosynthesis rate limited; plant stress.",
              "co2_range": "0.15–0.35 (200–400 ppm)"
            },
            "nextVectorIds": [
              "ag-atm-co2-depleted"
            ]
          },
          {
            "id": "ag-atm-co2-depleted",
            "elements": [
              {
                "value": 0.1,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.45,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "DEPLETED",
              "description": "DEPLETED — CO2 critically low (<200 ppm); photosynthesis halted. Fires CO2_INJECT.",
              "co2_range": "0.0–0.15 (<200 ppm)"
            },
            "outputVectors": [
              {
                "id": "ag-atm-co2-inject-output",
                "vector": [
                  1,
                  0,
                  0,
                  0
                ],
                "metadata": {
                  "description": "CO2_INJECT: open CO2 valve; restore enriched atmosphere at [36:40]",
                  "action": "Open CO2 regulator; enrichment cycle begins; IPM monitor registers CO2 stress"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "ag-atmos-humidity-escalation",
        "name": "Humidity Escalation: DRY_WATCH+ → HUMID → HIGH → CONDENSATION_RISK → HUMIDITY_ALERT",
        "metadata": {
          "description": "Detects rising relative humidity toward fungal disease risk. High humidity combined with low VPD reduces transpiration and creates conditions for botrytis and powdery mildew. Triggers ventilation before condensation forms.",
          "path": "DRY_WATCH+ → HUMID → HIGH → CONDENSATION_RISK → output[0,0,1,0]",
          "output": "[0,0,1,0] (HUMIDITY_ALERT)"
        },
