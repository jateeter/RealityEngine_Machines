            "id": "ag-atm-condensation-risk",
            "elements": [
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.93,
                "threshold": 0.5
              },
              {
                "value": 0.08,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "CONDENSATION_RISK",
              "description": "CONDENSATION_RISK — RH >92%; condensation forming on surfaces; botrytis/mildew risk critical. Fires HUMIDITY_ALERT.",
              "rh_range": "0.90–1.00 (>92% RH)",
              "vpd_range": "0.0–0.12 (<0.3 kPa)"
            },
