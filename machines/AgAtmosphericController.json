                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.45,
                "threshold": 0.5
              },
              {
                "value": 0.52,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "DRY_WATCH",
