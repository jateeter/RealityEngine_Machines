    "metadata": {
      "category": "agriculture",
      "domain": "Agriculture — Atmospheric CO2 / Humidity Control",
      "author": "Reality Engine",
      "outputSpace": "4D binary at [36:40]: [1,0,0,0]=CO2_INJECT, [0,1,0,0]=VENT_OPEN, [0,0,1,0]=HUMIDITY_ALERT, [0,0,0,1]=ATMOS_OK",
      "tags": [
        "ag-atmospheric-controller",
        "agriculture",
        "agriculture-atmospheric-co2-humidity-control",
