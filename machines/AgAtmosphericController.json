                "metadata": {
                  "description": "HUMIDITY_ALERT: open ventilation; activate dehumidifier at [36:40]",
                  "action": "Increase air exchange; IPM monitor registers elevated fungal pressure"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "ag-atmos-optimal",
        "name": "Optimal Atmosphere: OPTIMAL+ → ATMOS_OK",
        "metadata": {
          "description": "Fires ATMOS_OK when CO2, humidity, and VPD are all within optimal ranges for photosynthesis and transpiration.",
          "pattern": "OPTIMAL+",
          "output": "[0,0,0,1] (ATMOS_OK)"
        },
        "vectors": [
