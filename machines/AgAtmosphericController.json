            "isInitial": true,
            "metadata": {
              "name": "OPTIMAL",
              "description": "OPTIMAL+ — CO2 enriched, humidity moderate, VPD optimal, airflow adequate. Fires ATMOS_OK each matching cycle.",
              "co2_range": "0.55–0.70 (600–900 ppm)",
              "rh_range": "0.38–0.52 (55–68% RH)",
              "vpd_range": "0.48–0.58 (0.9–1.2 kPa)"
            },
            "outputVectors": [
              {
