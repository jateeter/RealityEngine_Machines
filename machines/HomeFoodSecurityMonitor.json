{
  "version": "1.0.0",
  "machine": {
    "name": "Home Food Security Monitor",
    "description": "Monitors household food access, meal frequency, and nutrition assistance engagement for low- and medium-income families receiving home-based care. Tracks the progression from adequate food access through food insecurity to crisis conditions requiring immediate SNAP, WIC, or food-bank referral. Output at [1995:1999] feeds the Adolescent Mental Health Monitor, reflecting the documented link between food insecurity and adolescent behavioral health outcomes.",
    "metadata": {
      "category": "health-personal",
      "domain": "Home Health — Social Determinants / Food Security",
      "author": "Reality Engine",
      "outputSpace": "4D binary at [1995:1999]: [1,0,0,0]=FOOD_CRISIS, [0,1,0,0]=FOOD_INSECURE, [0,0,1,0]=ASSISTANCE_NEEDED, [0,0,0,1]=FOOD_SECURE",
      "tags": [
        "benefits-eligibility",
