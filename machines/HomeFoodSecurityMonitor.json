        "low-income",
        "social-determinants",
        "startup-loadable"
      ],
      "sequenceCount": 3,
      "populationFocus": "Low- and medium-income households; families with children; adults on fixed incomes",
      "sensorNormalization": {
        "meal_frequency_norm": "0.0=zero adequate meals/day, 0.5=2–3 adequate meals/day (sufficient), 1.0=4+ meals/day",
        "food_quality_norm": "0.0=no nutritious food available, 0.5=adequate caloric and nutritional balance, 1.0=optimal nutrition with variety",
        "pantry_days_norm": "0.0=empty pantry (0 days supply), 0.5=3–5 day supply, 1.0=2+ week supply",
        "food_assistance_norm": "0.0=no assistance active (not enrolled or access lapsed), 0.5=partial benefit (SNAP pending/partial), 1.0=full assistance active (SNAP/WIC/food bank regular)"
      },
      "downstreamMachine": "AdolescentMentalHealthMonitor (reads [1995:1999])",
