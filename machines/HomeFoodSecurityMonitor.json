            "id": "hf-crisis",
            "elements": [
              {
                "value": 0.06,
                "threshold": 0.5
              },
              {
                "value": 0.05,
                "threshold": 0.5
              },
              {
                "value": 0.04,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "CRISIS",
              "description": "CRISIS — household not eating; no pantry supply; no food assistance active. Fires FOOD_CRISIS.",
              "meal_frequency": "0.0–0.10 (hunger; no adequate meals)",
              "food_assistance": "0.0–0.15 (no active benefits)"
            },
            "outputVectors": [
