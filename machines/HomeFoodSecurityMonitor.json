    "sequences": [
      {
        "id": "home-food-crisis-escalation",
        "name": "Food Security Deterioration: ADEQUATE+ → STRAINED → INSECURE → CRISIS → FOOD_CRISIS",
        "metadata": {
          "description": "Tracks progressive food access deterioration from adequate household supply through food insecurity to acute crisis. The ADEQUATE+ initial state requires at least one confirmed adequate period before escalation can proceed — distinguishing genuine decline from temporary data gaps.",
          "path": "ADEQUATE+ → STRAINED → INSECURE → CRISIS → output[1,0,0,0]",
          "output": "[1,0,0,0] (FOOD_CRISIS)"
        },
        "vectors": [
          {
            "id": "hf-adequate",
            "elements": [
              {
                "value": 0.6,
                "threshold": 0.5
              },
              {
                "value": 0.58,
                "threshold": 0.5
              },
              {
                "value": 0.55,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "ADEQUATE",
              "description": "ADEQUATE+ — 2–3 meals/day, reasonable food quality, several-day pantry supply. isInitial A*A = A+: at least one adequate period confirmed before STRAINED can arm.",
              "meal_frequency": "0.55–0.70 (2–3 solid meals/day)",
              "pantry_supply": "0.50–0.65 (3–7 day supply)"
            },
            "nextVectorIds": [
              "hf-adequate",
              "hf-strained"
            ]
          },
          {
            "id": "hf-strained",
            "elements": [
              {
                "value": 0.38,
                "threshold": 0.5
              },
              {
                "value": 0.35,
                "threshold": 0.5
              },
              {
                "value": 0.3,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "STRAINED",
              "description": "STRAINED — meal frequency dropping below 2/day; reduced food quality; pantry below 3-day supply.",
              "meal_frequency": "0.28–0.45 (1–2 meals/day)",
              "pantry_supply": "0.22–0.38 (1–3 day supply)"
            },
            "nextVectorIds": [
              "hf-insecure"
            ]
          },
          {
            "id": "hf-insecure",
            "elements": [
              {
                "value": 0.22,
                "threshold": 0.5
              },
              {
                "value": 0.2,
                "threshold": 0.5
              },
              {
                "value": 0.15,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "INSECURE",
              "description": "INSECURE — one meal or fewer per day; poor nutritional quality; near-empty pantry; assistance not active.",
              "meal_frequency": "0.12–0.28 (<1 adequate meal/day)",
              "pantry_supply": "0.08–0.18 (<1 day supply)"
            },
            "nextVectorIds": [
              "hf-crisis"
            ]
