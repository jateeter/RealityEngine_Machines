      "governance": {
        "schemaVersion": "1.0.0",
        "ownerTeam": "agriculture-operations",
        "runbook": "https://runbooks.example.org/agriculture/agzonetemperaturecontroller",
        "escalationPolicy": "pagerduty:ag-ops",
        "contact": {
          "primary": "agriculture-operations-primary@example.org",
          "secondary": "agriculture-operations-secondary@example.org"
        },
        "sla": {
          "ok": null,
          "info": null,
          "warning": 3600,
          "error": 900
        },
        "notes": "Auto-backfilled by scripts/backfill-governance.mjs from primaryDomain=\"agriculture\".  Review and tune the routing as the team owning AgZoneTemperatureController matures."
      },
      "triggerConfig": {
        "processId": "AGZONETEMPERATURECONTROLLER",
        "processName": "Ag Zone Temperature Controller",
        "rules": [
          {
            "sequenceId": "ag-zone-temp-overtemp",
            "outputMatches": [
              0,
              1,
              0,
              0
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "COOLING_ON: activate zone cooling system at [20:24]"
          },
          {
            "sequenceId": "ag-zone-temp-undertemp",
            "outputMatches": [
              1,
              0,
              0,
              0
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "HEATING_ON: activate zone heating at [20:24]"
          },
          {
            "sequenceId": "ag-zone-temp-optimal",
            "outputMatches": [
              0,
              0,
              0,
              1
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "TEMP_OK: zone temperature within optimal growth range at [20:24]"
          }
        ]
      }
    },
    "arbiterRule": "PASSTHROUGH",
    "perceptualMapping": {
      "input": {
        "offset": 0,
        "length": 4
      },
      "output": {
        "offset": 20,
        "length": 4
      },
      "bitsPerElement": 8
    },
    "sequences": [
      {
        "id": "ag-zone-temp-overtemp",
        "name": "OverTemp Escalation: WATCH+ → WARM → HOT → CRITICAL → COOLING_ON",
        "metadata": {
          "description": "Detects sustained temperature rise from nominal through warm to critically hot. isInitial WATCH provides the A+ kleene-plus pattern, requiring at least one observation before advancing.",
          "path": "WATCH+ → WARM → HOT → CRITICAL → output[0,1,0,0]",
          "output": "[0,1,0,0] (COOLING_ON)"
        },
        "vectors": [
          {
            "id": "ag-zt-watch-high",
            "elements": [
              {
                "value": 0.52,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "WATCH",
              "description": "WATCH+ — nominal-to-slightly-warm: air_temp just above threshold. isInitial A*A = A+: at least one observation before WARM can arm.",
              "air_temp_range": "0.50–0.62 (~24°C–28°C)",
              "root_temp_range": "wildcard"
            },
            "nextVectorIds": [
              "ag-zt-watch-high",
              "ag-zt-warm"
            ]
          },
          {
            "id": "ag-zt-warm",
            "elements": [
              {
                "value": 0.68,
                "threshold": 0.5
              },
              {
                "value": 0.63,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "WARM",
              "description": "WARM — temperatures clearly above optimal; single observation advances to HOT.",
              "air_temp_range": "0.62–0.74 (~28°C–31°C)",
              "root_temp_range": "0.58–0.68"
            },
            "nextVectorIds": [
              "ag-zt-hot"
            ]
          },
          {
            "id": "ag-zt-hot",
            "elements": [
              {
                "value": 0.82,
                "threshold": 0.5
              },
              {
                "value": 0.77,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "HOT",
              "description": "HOT — plant stress temperatures; requires WARM before activating.",
              "air_temp_range": "0.74–0.88 (~31°C–34°C)",
              "root_temp_range": "0.70–0.83"
            },
            "nextVectorIds": [
              "ag-zt-critical"
            ]
          },
          {
            "id": "ag-zt-critical",
            "elements": [
              {
                "value": 0.92,
                "threshold": 0.5
              },
              {
                "value": 0.88,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "CRITICAL",
              "description": "CRITICAL — thermal stress; fires COOLING_ON signal.",
              "air_temp_range": "0.87–1.00 (>33°C)",
              "root_temp_range": "0.83–1.00 (>29°C)"
            },
            "outputVectors": [
              {
                "id": "ag-zt-cooling-output",
                "vector": [
                  0,
                  1,
                  0,
                  0
                ],
                "metadata": {
                  "description": "COOLING_ON: activate zone cooling system at [20:24]",
                  "action": "Enable cooling; downstream AgPlantGrowthCycleMonitor will register high-temp condition"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "ag-zone-temp-undertemp",
        "name": "UnderTemp Escalation: COOL_WATCH+ → COOL → COLD → FROST → HEATING_ON",
        "metadata": {
          "description": "Detects progressive temperature drop toward frost conditions. Critical for protecting root zones and preventing cold-induced growth stall.",
          "path": "COOL_WATCH+ → COOL → COLD → FROST → output[1,0,0,0]",
          "output": "[1,0,0,0] (HEATING_ON)"
        },
        "vectors": [
          {
            "id": "ag-zt-cool-watch",
            "elements": [
              {
                "value": 0.32,
                "threshold": 0.5
              },
              {
                "value": 0.35,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "COOL_WATCH",
              "description": "COOL_WATCH+ — temperatures slightly below optimal but not alarming. isInitial A*A = A+.",
              "air_temp_range": "0.20–0.44 (~18°C–23°C)",
              "root_temp_range": "0.23–0.45"
            },
            "nextVectorIds": [
              "ag-zt-cool-watch",
              "ag-zt-cool"
            ]
          },
          {
            "id": "ag-zt-cool",
            "elements": [
              {
                "value": 0.2,
                "threshold": 0.5
