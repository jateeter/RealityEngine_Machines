          {
            "id": "ag-zt-frost",
            "elements": [
              {
                "value": 0.05,
                "threshold": 0.5
              },
              {
                "value": 0.06,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "FROST",
              "description": "FROST — near-freezing conditions; fires HEATING_ON.",
              "air_temp_range": "0.0–0.10 (<17°C with significant root-zone drop)"
            },
            "outputVectors": [
              {
                "id": "ag-zt-heating-output",
                "vector": [
                  1,
                  0,
                  0,
                  0
                ],
                "metadata": {
                  "description": "HEATING_ON: activate zone heating at [20:24]",
                  "action": "Enable heating; frost risk prevention mode"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "ag-zone-temp-optimal",
        "name": "Optimal Temperature: OPTIMAL+ → TEMP_OK",
        "metadata": {
          "description": "Fires TEMP_OK signal whenever zone temperatures are within the optimal growth range. Provides continuous 'all-clear' signal to downstream monitors.",
          "pattern": "OPTIMAL+",
          "output": "[0,0,0,1] (TEMP_OK)"
        },
        "vectors": [
          {
            "id": "ag-zt-optimal",
            "elements": [
              {
                "value": 0.44,
                "threshold": 0.5
              },
              {
                "value": 0.42,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "OPTIMAL",
              "description": "OPTIMAL+ — both temps below threshold (within safe range). isInitial A*A = A+: fires TEMP_OK on every matching cycle.",
              "air_temp_range": "0.36–0.50 (~22°C–26°C)",
              "root_temp_range": "0.34–0.48 (~19°C–23°C)"
            },
            "outputVectors": [
              {
                "id": "ag-zt-ok-output",
                "vector": [
                  0,
                  0,
                  0,
                  1
                ],
                "metadata": {
                  "description": "TEMP_OK: zone temperature within optimal growth range at [20:24]",
                  "action": "Downstream AgPlantGrowthCycleMonitor registers healthy temp condition"
                }
              }
            ]
          }
        ]
      }
    ],
    "inputSequences": [
