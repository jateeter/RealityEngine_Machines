{
  "version": "1.0.0",
  "machine": {
    "name": "Ag Zone Temperature Controller",
    "description": "Monitors air and root-zone temperature to detect overheating and frost risk in indoor growing zones. Implements two concurrent escalation patterns (OVERTEMP and UNDERTEMP) plus a continuous OPTIMAL signal. Upstream: raw zone sensors at [0:4]. Downstream: AgPlantGrowthCycleMonitor reads output at [20:24].",
    "metadata": {
      "category": "agriculture",
      "domain": "Agriculture — Zone Climate / Temperature",
      "author": "Reality Engine",
      "outputSpace": "4D binary at [20:24]: [1,0,0,0]=HEATING_ON, [0,1,0,0]=COOLING_ON, [0,0,1,0]=VPD_ALERT, [0,0,0,1]=TEMP_OK",
      "tags": [
        "ag-zone-temperature-controller",
        "agriculture",
        "agriculture-indoor-grow-house",
        "agriculture-zone-climate-temperature",
        "ces-sequences",
        "ces-sequences-3",
        "heating",
        "indoor-growing",
        "input-sequences",
        "input-sequences-2",
        "kleene-plus",
        "startup-loadable",
        "temperature",
        "thermal-comfort",
        "zone-climate",
        "zone-temperature"
      ],
      "sequenceCount": 3,
      "sensorNormalization": {
        "air_temp_norm": "0.0=15°C, 0.5=24°C (optimal), 1.0=35°C",
        "root_zone_temp_norm": "0.0=12°C, 0.5=22°C (optimal), 1.0=32°C",
        "heater_status": "0.0=off, 1.0=on (active heating)",
        "cooler_status": "0.0=off, 1.0=on (active cooling)"
      },
      "downstreamMachine": "AgPlantGrowthCycleMonitor (reads [20:24])",
      "tagging": {
        "schemaVersion": "1.0.0",
        "managedBy": "scripts/manage_machine_tags.mjs",
        "primaryDomain": "agriculture",
        "domainTags": [
          "agriculture",
          "temperature",
          "zone-climate"
        ],
        "family": "ag-zone-temperature-controller",
        "machineCode": "ag-zone-temperature-controller",
        "capabilityTags": [],
        "workflowTags": [
          "agriculture-indoor-grow-house",
          "agriculture-zone-climate-temperature",
          "heating",
