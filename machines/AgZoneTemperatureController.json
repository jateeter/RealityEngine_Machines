            ],
            "isInitial": false,
            "metadata": {
              "name": "COOL",
              "description": "COOL — temperatures dropping; growth slowing.",
              "air_temp_range": "0.12–0.28 (~17°C–20°C)"
            },
            "nextVectorIds": [
              "ag-zt-cold"
            ]
          },
