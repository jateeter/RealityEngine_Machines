                }
              }
            ]
          }
        ]
      }
    ],
    "inputSequences": [
      {
        "name": "Quiescent \u2014 no above-threshold samples",
        "description": "Count of 0: firmware reports no motion samples above threshold this tick. Pre-aggregator classifies as MOTION_NONE (ordinal 0).",
        "vectors": [
