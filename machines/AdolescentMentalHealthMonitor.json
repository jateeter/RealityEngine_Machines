{
  "version": "1.0.0",
  "machine": {
    "name": "Adolescent Mental Health Monitor",
    "description": "Integration machine that reads combined output signals from the Home Food Security Monitor [1995:1999] and the Home Environment Safety Monitor [1999:2003] to detect adolescent mental health risk driven by co-occurring social adversities. Food insecurity and housing instability are the two most predictive household stressors for adolescent depression, anxiety, and behavioral health crises. Monitors mood indicators, school engagement, risk behavior, and family conflict as 8D integrated input. Output at [2027:2031] is available to downstream care coordination systems.",
    "metadata": {
      "category": "health-personal",
      "domain": "Home Health — Adolescent / Behavioral Health",
      "author": "Reality Engine",
      "outputSpace": "4D binary at [2027:2031]: [1,0,0,0]=CRISIS_RISK, [0,1,0,0]=BEHAVIORAL_CONCERN, [0,0,1,0]=ELEVATED_STRESS, [0,0,0,1]=MENTAL_HEALTH_OK",
      "tags": [
        "adolescent",
        "adolescent-mental-health-monitor",
        "behavioral-health",
        "ces-sequences",
        "ces-sequences-3",
        "food-insecurity",
        "health-personal",
        "home-health",
        "home-health-adolescent-behavioral-health",
        "housing-instability",
        "input-sequences",
        "input-sequences-1",
        "kleene-plus",
        "life-balance-adolescent-family-and-school",
        "low-income",
        "mental-health",
        "startup-loadable"
      ],
      "sequenceCount": 3,
      "populationFocus": "Adolescents ages 12–18 in food-insecure and housing-unstable households; low-income youth without behavioral health access",
      "sensorNormalization": {
        "food_security_signal_norm": "0.0=[1,0,0,0] FOOD_CRISIS from upstream (bit 342), 0.5=[0,0,1,0] ASSISTANCE_NEEDED (bit 344), 1.0=[0,0,0,1] FOOD_SECURE (bit 345)",
        "housing_safety_signal_norm": "0.0=[1,0,0,0] UNSAFE_HOUSING from upstream (bit 346), 0.5=[0,0,1,0] HEALTH_HAZARD_RISK (bit 348), 1.0=[0,0,0,1] ENVIRONMENT_SAFE (bit 349)",
        "mood_engagement_norm": "0.0=persistent low mood; school absence; social withdrawal; expressed hopelessness, 0.5=variable mood; inconsistent engagement; some withdrawal, 1.0=age-appropriate mood and engagement",
        "risk_behavior_norm": "0.0=active risk behaviors (self-harm, substance use, truancy, violence), 0.5=risk factors present (peer conflict, some substance experimentation, declining grades), 1.0=no identified risk behaviors"
      },
      "upstreamMachines": [
        "HomeFoodSecurityMonitor (output [1995:1999])",
        "HomeEnvironmentSafetyMonitor (output [1999:2003])"
      ],
