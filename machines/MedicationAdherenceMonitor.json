{
  "version": "1.0.0",
  "machine": {
    "name": "Medication Adherence Monitor",
    "description": "Tracks whether scheduled medication doses are acknowledged within the allotted window. Signals the local AI to trigger reminders, caregiver alerts, or clinical follow-up when doses are delayed or missed outright.",
    "metadata": {
      "category": "health-personal",
      "domain": "wellness",
      "author": "Reality Engine",
      "created": "2026-04-21T00:00:00Z",
      "workflow": "in-home-medication-adherence",
      "eventSpace": "2D binary: [dose_pending, dose_confirmed]",
      "outputSpace": "2D binary: {[0,0]=NOMINAL, [1,0]=DELAYED, [1,1]=MISSED}",
      "tags": [
        "ces-sequences",
        "ces-sequences-3",
        "elder-care",
        "health-personal",
        "in-home-monitoring",
        "input-sequences",
        "input-sequences-2",
        "medication",
        "medication-adherence-monitor",
        "startup-loadable",
        "trigger",
        "wellness"
      ],
      "sequenceCount": 3,
      "triggerConfig": {
        "endpoint": "http://localhost:4000/graphql",
        "template": "examples/triggers/graphql_trigger_template.py",
        "processId": "MEDICATION-ADHERENCE",
        "processName": "Medication Adherence Monitor",
        "rules": [
          {
            "sequenceId": "med-taken-on-time",
            "outputMatches": [
              0,
              0
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "ok",
            "description": "Dose acknowledged within window"
          },
          {
            "sequenceId": "med-delayed",
            "outputMatches": [
              1,
              0
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "Dose pending past reminder window — nudge the patient / caregiver"
          },
          {
            "sequenceId": "med-missed",
            "outputMatches": [
              1,
              1
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "Dose missed past grace window — escalate to clinical contact"
          }
        ]
      },
      "tagging": {
        "schemaVersion": "1.0.0",
        "managedBy": "scripts/manage_machine_tags.mjs",
        "primaryDomain": "health-personal",
        "domainTags": [
          "health-personal",
          "wellness"
        ],
        "family": "medication-adherence-monitor",
        "machineCode": "medication-adherence-monitor",
        "capabilityTags": [
          "in-home-monitoring"
        ],
        "workflowTags": [
          "elder-care",
          "medication",
          "trigger"
        ],
        "integrationTags": [],
        "validationTags": [
          "ces-sequences",
          "ces-sequences-3",
          "input-sequences",
          "input-sequences-2",
          "startup-loadable"
        ],
        "allTags": [
          "ces-sequences",
          "ces-sequences-3",
          "elder-care",
          "health-personal",
          "in-home-monitoring",
          "input-sequences",
          "input-sequences-2",
          "medication",
          "medication-adherence-monitor",
          "startup-loadable",
          "trigger",
          "wellness"
        ]
      },
      "governance": {
        "schemaVersion": "1.0.0",
        "ownerTeam": "patient-safety-on-call",
        "runbook": "https://runbooks.example.org/health-personal/medicationadherencemonitor",
        "escalationPolicy": "pagerduty:patient-safety",
        "contact": {
          "primary": "patient-safety-on-call-primary@example.org",
          "secondary": "patient-safety-on-call-secondary@example.org"
        },
        "sla": {
          "ok": null,
          "info": null,
          "warning": 600,
          "error": 60
        },
        "notes": "Auto-backfilled by scripts/backfill-governance.mjs from primaryDomain=\"health-personal\".  Review and tune the routing as the team owning MedicationAdherenceMonitor matures."
      }
    },
    "arbiterRule": "PASSTHROUGH",
    "perceptualMapping": {
      "input": {
        "offset": 1939,
        "length": 2
      },
      "output": {
        "offset": 3811,
        "length": 2
      },
      "bitsPerElement": 1
    },
    "sequences": [
      {
        "id": "med-taken-on-time",
        "name": "Dose taken on time → GREEN",
        "metadata": {
          "description": "Dose confirmed within the scheduled window"
        },
        "vectors": [
          {
            "id": "med-ev-confirmed",
            "elements": [
              {
                "value": 0,
                "threshold": 0.5
              },
              {
                "value": 1,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "confirmed",
              "state": "NOMINAL"
            },
            "outputVectors": [
              {
                "id": "med-out-nominal",
                "vector": [
                  0,
                  0
                ],
                "metadata": {
                  "ragStatusCode": "GREEN",
                  "state": "NOMINAL"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "med-delayed",
        "name": "Dose delayed → AMBER",
        "metadata": {
          "description": "Pending dose not yet confirmed after reminder window"
        },
        "vectors": [
          {
            "id": "med-ev-delayed",
            "elements": [
              {
                "value": 1,
                "threshold": 0.5
              },
              {
                "value": 0,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "delayed",
              "state": "DELAYED"
            },
            "outputVectors": [
              {
                "id": "med-out-delayed",
                "vector": [
                  1,
                  0
                ],
                "metadata": {
                  "ragStatusCode": "AMBER",
                  "state": "DELAYED"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "med-missed",
        "name": "Dose missed → RED",
        "metadata": {
          "description": "Dose still pending past grace window — escalation required"
        },
        "vectors": [
          {
            "id": "med-ev-missed",
            "elements": [
              {
                "value": 1,
                "threshold": 0.5
              },
              {
                "value": 1,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "missed",
              "state": "MISSED"
            },
            "outputVectors": [
              {
                "id": "med-out-missed",
                "vector": [
                  1,
                  1
                ],
                "metadata": {
                  "ragStatusCode": "RED",
                  "state": "MISSED"
                }
              }
            ]
          }
        ]
      }
    ],
    "inputSequences": [
      {
        "name": "On-time dose",
        "pattern": "[0,1]",
        "description": "Patient confirms the dose within the window — expects GREEN trigger",
        "vectors": [
          [
            0,
            0
          ],
          [
            0,
            1
          ],
          [
            0,
            0
          ]
        ]
      },
      {
        "name": "Delayed dose → missed dose",
        "pattern": "[1,0] → [1,1]",
        "description": "Reminder window elapses (AMBER), then grace window elapses (RED)",
        "vectors": [
          [
            0,
            0
          ],
          [
            1,
            0
          ],
          [
            1,
            1
          ],
          [
            0,
            0
          ]
        ]
      }
    ],
    "matchAlgorithm": "gte"
  }
}
