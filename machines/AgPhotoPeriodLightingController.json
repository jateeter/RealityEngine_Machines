          ]
        ],
        "metadata": {
          "scenario": "vegetative-18-6-cycle",
          "expectedOutputs": {
            "steps_1_2": "DARK_PERIOD self-loops; no output (dark period accumulating)",
            "step_3": "no output (TRANSITION intermediate)",
            "step_4": "no output (ACTIVE intermediate)",
            "step_5": "LIGHTS_ON fires [1,0,0,0] (peak intensity reached)",
            "step_6": "PHOTO_OK fires [0,0,0,1]",
            "step_7": "no output (DLI_NEAR_TARGET intermediate)",
            "step_8": "LIGHTS_OFF fires [0,1,0,0] (DLI target met)"
