        "schemaVersion": "1.0.0",
        "ownerTeam": "agriculture-operations",
        "runbook": "https://runbooks.example.org/agriculture/agphotoperiodlightingcontroller",
        "escalationPolicy": "pagerduty:ag-ops",
        "contact": {
          "primary": "agriculture-operations-primary@example.org",
          "secondary": "agriculture-operations-secondary@example.org"
        },
        "sla": {
          "ok": null,
          "info": null,
          "warning": 3600,
          "error": 900
        },
        "notes": "Auto-backfilled by scripts/backfill-governance.mjs from primaryDomain=\"agriculture\".  Review and tune the routing as the team owning AgPhotoPeriodLightingController matures."
      },
      "triggerConfig": {
        "processId": "AGPHOTOPERIODLIGHTINGCONTROLLER",
        "processName": "Ag Photo Period Lighting Controller",
        "rules": [
          {
            "sequenceId": "ag-photo-lights-on-cycle",
            "outputMatches": [
              1,
              0,
              0,
              0
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "LIGHTS_ON: light cycle active and at peak intensity at [32:36]"
          },
          {
            "sequenceId": "ag-photo-lights-off-cycle",
            "outputMatches": [
              0,
              1,
              0,
              0
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "LIGHTS_OFF: DLI target met; begin dark period at [32:36]"
          },
          {
            "sequenceId": "ag-photo-ok",
            "outputMatches": [
              0,
              0,
              0,
              1
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "PHOTO_OK: photoperiod within optimal parameters at [32:36]"
          }
        ]
      }
    },
    "arbiterRule": "PASSTHROUGH",
    "perceptualMapping": {
      "input": {
        "offset": 12,
        "length": 4
      },
      "output": {
        "offset": 32,
        "length": 4
      },
      "bitsPerElement": 8
    },
    "sequences": [
      {
        "id": "ag-photo-lights-on-cycle",
        "name": "Light Cycle Start: DARK_PERIOD+ → TRANSITION → ACTIVE → PEAK → LIGHTS_ON",
        "metadata": {
          "description": "Detects when the scheduled dark period has been satisfied and the photoperiod timer arms the light cycle. DARK_PERIOD+ ensures adequate dark rest before re-activating lights — critical for photoperiod-sensitive crops.",
          "path": "DARK_PERIOD+ → TRANSITION → ACTIVE → PEAK → output[1,0,0,0]",
          "output": "[1,0,0,0] (LIGHTS_ON)"
        },
        "vectors": [
          {
            "id": "ag-ph-dark-period",
            "elements": [
              {
                "value": 0.05,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              },
              {
                "value": 0.08,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "DARK_PERIOD",
              "description": "DARK_PERIOD+ — PAR near zero, early in period, DLI not yet accumulated, dark period active. isInitial A*A = A+: at least one full dark cycle confirmed before lights can arm.",
              "par_range": "0.0–0.10 (near-dark, no light leak)",
              "dark_integrity": "0.0–0.15 (dark period fully active)"
            },
            "nextVectorIds": [
              "ag-ph-dark-period",
              "ag-ph-transition"
            ]
          },
          {
            "id": "ag-ph-transition",
            "elements": [
              {
                "value": 0.25,
                "threshold": 0.5
              },
              {
                "value": 0.15,
                "threshold": 0.5
              },
              {
                "value": 0.18,
                "threshold": 0.5
              },
              {
                "value": 0.08,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "TRANSITION",
              "description": "TRANSITION — lamp warm-up; PAR rising from dark to active level.",
              "par_range": "0.10–0.40 (ramp-up)"
            },
            "nextVectorIds": [
              "ag-ph-active"
            ]
          },
          {
            "id": "ag-ph-active",
            "elements": [
              {
                "value": 0.55,
                "threshold": 0.5
              },
              {
                "value": 0.35,
                "threshold": 0.5
              },
              {
                "value": 0.35,
                "threshold": 0.5
              },
              {
                "value": 0.08,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "ACTIVE",
              "description": "ACTIVE — lights at photosynthetically effective intensity; photoperiod in progress.",
              "par_range": "0.50–0.70 (400–600 µmol/m²/s)"
            },
            "nextVectorIds": [
              "ag-ph-peak"
            ]
          },
          {
            "id": "ag-ph-peak",
            "elements": [
              {
                "value": 0.82,
                "threshold": 0.5
              },
              {
                "value": 0.58,
                "threshold": 0.5
              },
              {
                "value": 0.62,
                "threshold": 0.5
              },
              {
                "value": 0.08,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "PEAK",
              "description": "PEAK — maximum scheduled PAR intensity; DLI accumulating well. Fires LIGHTS_ON confirmation.",
              "par_range": "0.75–0.90 (700–900 µmol/m²/s)"
            },
            "outputVectors": [
              {
                "id": "ag-ph-lights-on-output",
                "vector": [
                  1,
                  0,
                  0,
                  0
                ],
                "metadata": {
                  "description": "LIGHTS_ON: light cycle active and at peak intensity at [32:36]",
                  "action": "Downstream IPM and nutrient cycle monitors register active photoperiod"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "ag-photo-lights-off-cycle",
        "name": "DLI Target Met: DLI_BUILDING+ → DLI_NEAR_TARGET → DLI_MET → LIGHTS_OFF",
        "metadata": {
          "description": "Fires LIGHTS_OFF when the daily DLI target has been met. Prevents over-lighting (photooxidative stress) by terminating the light period once sufficient photons have been delivered.",
          "path": "DLI_BUILDING+ → DLI_NEAR_TARGET → DLI_MET → output[0,1,0,0]",
          "output": "[0,1,0,0] (LIGHTS_OFF)"
        },
        "vectors": [
          {
            "id": "ag-ph-dli-building",
            "elements": [
              {
                "value": 0.6,
                "threshold": 0.5
              },
              {
                "value": 0.45,
                "threshold": 0.5
              },
              {
                "value": 0.35,
                "threshold": 0.5
              },
              {
                "value": 0.08,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "DLI_BUILDING",
              "description": "DLI_BUILDING+ — lights active, DLI accumulating toward target. isInitial A*A = A+.",
              "dli_range": "0.25–0.45 (10–18 mol/m²/d accumulated)"
            },
            "nextVectorIds": [
              "ag-ph-dli-building",
              "ag-ph-dli-near"
            ]
          },
          {
            "id": "ag-ph-dli-near",
            "elements": [
              {
                "value": 0.65,
                "threshold": 0.5
              },
              {
                "value": 0.72,
                "threshold": 0.5
              },
              {
                "value": 0.72,
                "threshold": 0.5
              },
              {
                "value": 0.08,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "DLI_NEAR_TARGET",
              "description": "DLI_NEAR_TARGET — approaching daily target; prepare to transition lights off.",
              "dli_range": "0.65–0.82 (26–33 mol/m²/d)"
            },
            "nextVectorIds": [
              "ag-ph-dli-met"
            ]
          },
          {
            "id": "ag-ph-dli-met",
            "elements": [
              {
                "value": 0.65,
                "threshold": 0.5
              },
              {
                "value": 0.88,
                "threshold": 0.5
              },
              {
                "value": 0.9,
                "threshold": 0.5
              },
              {
                "value": 0.08,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "DLI_MET",
              "description": "DLI_MET — daily light integral target reached. Fires LIGHTS_OFF to begin dark period.",
              "dli_range": "0.88–1.00 (35+ mol/m²/d)"
            },
            "outputVectors": [
              {
                "id": "ag-ph-lights-off-output",
                "vector": [
                  0,
                  1,
                  0,
                  0
                ],
                "metadata": {
                  "description": "LIGHTS_OFF: DLI target met; begin dark period at [32:36]",
                  "action": "Power down grow lights; dark period timer starts"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "ag-photo-ok",
        "name": "Optimal Photoperiod: PHOTO_OK+ → PHOTO_OK signal",
        "metadata": {
          "description": "Fires PHOTO_OK when lights are actively delivering PAR within optimal range and dark period integrity is maintained. Provides continuous healthy-lighting signal.",
          "pattern": "PHOTO_OK+",
          "output": "[0,0,0,1] (PHOTO_OK)"
        },
        "vectors": [
          {
            "id": "ag-ph-optimal",
            "elements": [
              {
                "value": 0.58,
                "threshold": 0.5
              },
              {
                "value": 0.42,
                "threshold": 0.5
              },
              {
                "value": 0.48,
                "threshold": 0.5
              },
              {
                "value": 0.08,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "PHOTO_OK",
              "description": "PHOTO_OK+ — PAR in optimal vegetative range, mid-photoperiod, DLI building well, dark period clean. Fires on every matching cycle.",
              "par_range": "0.52–0.68 (400–550 µmol/m²/s, optimal vegetative)",
              "dli_range": "0.40–0.55 (mid-accumulation)"
            },
            "outputVectors": [
              {
                "id": "ag-ph-ok-output",
                "vector": [
                  0,
                  0,
                  0,
                  1
                ],
                "metadata": {
                  "description": "PHOTO_OK: photoperiod within optimal parameters at [32:36]",
                  "action": "Downstream nutrient and IPM monitors register healthy light environment"
                }
              }
            ]
          }
        ]
      }
    ],
    "inputSequences": [
      {
        "name": "18/6 Vegetative Photoperiod Cycle",
        "pattern": "8-step: DARK→DARK→TRANSITION→ACTIVE→PEAK→PHOTO_OK→DLI_NEAR→DLI_MET",
        "description": "Full 18-hour light / 6-hour dark vegetative cycle compressed to representative samples.",
        "vectors": [
