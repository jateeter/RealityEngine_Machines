{
  "version": "1.0.0",
  "machine": {
    "name": "Ag Photo Period Lighting Controller",
    "description": "Controls photoperiod and light intensity for indoor growing zones. Monitors PAR (photosynthetically active radiation) intensity, accumulated daily light integral (DLI), and dark-period integrity. Fires LIGHTS_ON/OFF transitions and DLI insufficiency alerts. Upstream: light sensors at [12:16]. Downstream: AgNutrientCycleOptimizer and AgIPMPestAlertMonitor read output at [32:36].",
    "metadata": {
      "category": "agriculture",
      "domain": "Agriculture — Photoperiod / Lighting Control",
      "author": "Reality Engine",
      "outputSpace": "4D binary at [32:36]: [1,0,0,0]=LIGHTS_ON, [0,1,0,0]=LIGHTS_OFF, [0,0,1,0]=DLI_ALERT, [0,0,0,1]=PHOTO_OK",
      "tags": [
        "ag-photo-period-lighting-controller",
        "agriculture",
        "agriculture-indoor-grow-house",
        "agriculture-photoperiod-lighting-control",
        "ces-sequences",
        "ces-sequences-3",
        "dli",
        "indoor-growing",
        "input-sequences",
        "input-sequences-1",
        "kleene-plus",
        "lighting",
        "lighting-control",
        "machine-interconnect",
        "par",
        "photoperiod",
        "photosynthesis",
        "startup-loadable"
      ],
      "sequenceCount": 3,
      "sensorNormalization": {
        "par_intensity_norm": "0.0=dark, 0.5=400 µmol/m²/s (vegetative optimal), 1.0=1000 µmol/m²/s",
        "photoperiod_elapsed_norm": "0.0=start of light period, 0.5=mid-period, 1.0=full period complete",
        "dli_accumulated_norm": "0.0=0 mol/m²/d, 0.5=20 mol/m²/d (vegetative target), 1.0=40+ mol/m²/d",
        "dark_period_integrity_norm": "0.0=dark period fully satisfied, 0.5=partial dark, 1.0=no dark period (light leak)"
      },
      "downstreamMachines": [
        "AgNutrientCycleOptimizer (reads [32:36])",
        "AgIPMPestAlertMonitor (reads [32:36])"
      ],
      "tagging": {
