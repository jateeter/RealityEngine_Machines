        "metadata": {
          "description": "Detects clients who were confirmed eligible and intake-complete but whose enrollment has stalled and then lapsed — the invisible failure where eligible clients simply never receive services. This is the most consequential gap in community services: the determination was made correctly, the intake was done, but the handoff to enrollment broke down. Requires ON_TRACK+ baseline before failure escalation arms.",
          "path": "ON_TRACK+ → STALLED → LAPSED → output[1,0,0,0]",
          "output": "[1,0,0,0] (ENROLLMENT_FAILURE)"
        },
