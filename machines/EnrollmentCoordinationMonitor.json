{
  "version": "1.0.0",
  "machine": {
    "name": "Enrollment Coordination Monitor",
    "description": "Integration machine that reads combined output signals from the Benefits Eligibility Screener [952:956] and the Service Intake Assessment Monitor [956:960] to detect enrollment coordination failures — cases where eligible, assessed clients are not transitioning into active services. The gap between confirmed eligibility and actual enrollment is the most significant service delivery failure in community programs: eligible people who never get enrolled. Output at [984:988] is available to downstream care coordination systems.",
    "metadata": {
      "category": "community-services",
      "domain": "Community Services — Enrollment Coordination / Access",
      "author": "Reality Engine",
      "outputSpace": "4D binary at [984:988]: [1,0,0,0]=ENROLLMENT_FAILURE, [0,1,0,0]=ENROLLMENT_BARRIER, [0,0,1,0]=ENROLLMENT_DELAYED, [0,0,0,1]=ENROLLMENT_ON_TRACK",
      "tags": [
        "access",
        "benefits-eligibility",
        "ces-sequences",
        "ces-sequences-3",
        "community-services",
        "community-services-enrollment-coordination-access",
        "enrollment-coordination",
        "enrollment-coordination-monitor",
        "input-sequences",
        "input-sequences-1",
        "intake",
        "kleene-plus",
        "service-delivery",
        "startup-loadable"
      ],
      "sequenceCount": 3,
      "populationFocus": "Eligible community service applicants who have completed intake but not enrolled; clients in the gap between determination and benefits issuance",
      "sensorNormalization": {
        "eligibility_signal_norm": "0.0=[1,0,0,0] ELIGIBILITY_DENIED from BenefitsEligibilityScreener (bit 430), 0.5=[0,0,1,0] DOCUMENTATION_NEEDED (bit 432), 1.0=[0,0,0,1] ELIGIBILITY_CONFIRMED (bit 433)",
        "intake_signal_norm": "0.0=[1,0,0,0] PRIORITY_INTAKE from ServiceIntake (bit 434), 0.5=[0,1,0,0] COMPLEX_INTAKE (bit 435), 1.0=[0,0,0,1] INTAKE_COMPLETE (bit 437)",
        "enrollment_progress_norm": "0.0=no enrollment steps initiated despite confirmed eligibility and complete intake, 0.5=enrollment in process but stalled at a workflow step, 1.0=enrollment completed; benefits issued or services initiated",
        "worker_assignment_norm": "0.0=no case worker assigned (client in queue with no owner), 0.5=assigned but worker caseload preventing timely action, 1.0=case worker assigned and first contact made"
      },
      "upstreamMachines": [
        "BenefitsEligibilityScreener (output [952:956])",
        "ServiceIntakeAssessmentMonitor (output [956:960])"
      ],
