            "sequenceId": "enrollment-barrier",
            "outputMatches": [
              0,
              1,
              0,
              0
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "ENROLLMENT_BARRIER: eligible client facing functional or logistical barriers to completing enrollment at [984:988]"
          },
          {
            "sequenceId": "enrollment-on-track-ok",
            "outputMatches": [
              0,
              0,
              0,
              1
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "ENROLLMENT_ON_TRACK: eligible client through intake and moving toward active enrollment at [984:988]"
          }
        ]
      }
    },
    "arbiterRule": "PASSTHROUGH",
