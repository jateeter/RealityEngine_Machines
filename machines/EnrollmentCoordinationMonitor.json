        "processId": "ENROLLMENTCOORDINATIONMONITOR",
        "processName": "Enrollment Coordination Monitor",
        "rules": [
          {
            "sequenceId": "enrollment-failure-escalation",
            "outputMatches": [
              1,
              0,
              0,
              0
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "ENROLLMENT_FAILURE: eligible client not enrolled; urgent needs unmet; enrollment pathway collapsed at [984:988]"
          },
