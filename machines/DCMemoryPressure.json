{
  "version": "1.0.0",
  "machine": {
    "name": "DC Memory Pressure Detector",
    "description": "Monitors memory utilization and swap usage to detect memory pressure escalating to thrashing and cascading failure. Implements the regular expression NORMAL+ → PRESSURE+ → THRASHING → CASCADING+ → FAILURE → [alarm]. A concurrent HEALTHY+ sequence fires the reset signal when memory is within safe parameters.",
    "metadata": {
      "category": "data-center",
      "domain": "Data Center — Memory / Pressure",
      "author": "Reality Engine",
      "created": "2026-02-27T00:00:00Z",
      "eventSpace": "4D continuous sensor vector at [1344:1348]: [mem_usage_norm, mem_page_fault_rate_norm, mem_cache_miss_norm, swap_usage_norm]",
      "outputSpace": "2D binary at [1367:1369]: [1,0]=MEMORY_ALARM, [0,1]=MEMORY_HEALTHY",
      "tags": [
        "anomaly-detection",
        "cascading-failure",
        "ces-sequences",
        "ces-sequences-2",
