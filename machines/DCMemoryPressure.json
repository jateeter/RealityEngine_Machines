        "pressure",
        "startup-loadable",
        "thrashing"
      ],
      "sequenceCount": 2,
      "downstreamMachine": "DCMemoryAlertFF (reads [1367:1369])",
      "regularExpression": {
        "escalation": "NORMAL+ → PRESSURE+ → THRASHING → CASCADING+ → FAILURE → output[1,0]",
        "recovery": "HEALTHY+ → output[0,1]",
        "combined": "Models memory-induced system degradation: elevated usage (PRESSURE+) leads to page thrashing (THRASHING), which cascades into swap exhaustion (CASCADING+), ultimately causing system failure (FAILURE). Each stage requires sustained observation before advancing, preventing false alarms.",
        "isInitialNote": "NORMAL and HEALTHY are isInitial vectors implementing A*A = A+. At least one NORMAL reading is required to arm PRESSURE; at least one HEALTHY reading is required to produce the reset output. NORMAL* or HEALTHY* would be incorrect — they would imply successors can be armed or output produced without any matching sensor observation."
      },
      "sensorNormalization": {
        "mem_usage_norm": "0.0 = 0% memory used, 1.0 = 100% memory used",
        "mem_page_fault_rate_norm": "wildcard (don't care — value=0.5, tolerance=0.5)",
        "mem_cache_miss_norm": "wildcard (don't care — value=0.5, tolerance=0.5)",
        "swap_usage_norm": "0.0 = no swap used, 1.0 = swap exhausted"
      },
      "singleTransitionAssumption": {
        "required": false,
        "scope": "continuous sensor space — STA not applicable as defined for binary vectors",
        "compliant": true,
        "notes": "Continuous-space STA analog: gradual memory utilization progression through bands. Memory thrashing typically develops gradually as physical memory fills and the OS begins paging. An abrupt jump from NORMAL to FAILURE (without observed PRESSURE+ or THRASHING transitions) would not trigger the alarm, correctly filtering out measurement artifacts or OOM-killer actions that restore memory suddenly. NORMAL is isInitial (A*A = A+): at least one NORMAL reading is required to arm PRESSURE."
      },
