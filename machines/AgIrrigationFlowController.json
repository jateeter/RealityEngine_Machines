        ]
      },
      "governance": {
        "schemaVersion": "1.0.0",
        "ownerTeam": "agriculture-operations",
        "runbook": "https://runbooks.example.org/agriculture/agirrigationflowcontroller",
        "escalationPolicy": "pagerduty:ag-ops",
        "contact": {
          "primary": "agriculture-operations-primary@example.org",
          "secondary": "agriculture-operations-secondary@example.org"
        },
        "sla": {
          "ok": null,
          "info": null,
          "warning": 3600,
          "error": 900
        },
        "notes": "Auto-backfilled by scripts/backfill-governance.mjs from primaryDomain=\"agriculture\".  Review and tune the routing as the team owning AgIrrigationFlowController matures."
      },
      "triggerConfig": {
        "processId": "AGIRRIGATIONFLOWCONTROLLER",
        "processName": "Ag Irrigation Flow Controller",
        "rules": [
          {
            "sequenceId": "ag-irrig-drydown",
            "outputMatches": [
              1,
              0,
              0,
              0
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "IRRIGATE_ON: open irrigation valve and run pump at [24:28]"
          },
          {
            "sequenceId": "ag-irrig-waterlog",
            "outputMatches": [
              0,
              1,
              0,
              0
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "DRAIN_ALERT: open drain valve; halt irrigation pump at [24:28]"
          },
          {
            "sequenceId": "ag-irrig-balanced",
            "outputMatches": [
              0,
              0,
              0,
              1
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "FLOW_OK: optimal irrigation cycle active at [24:28]"
          }
        ]
      }
    },
    "arbiterRule": "PASSTHROUGH",
    "perceptualMapping": {
      "input": {
        "offset": 4,
        "length": 4
      },
      "output": {
        "offset": 24,
        "length": 4
      },
      "bitsPerElement": 8
    },
    "sequences": [
      {
        "id": "ag-irrig-drydown",
        "name": "Dry-Down Escalation: MOIST+ → DRY → VERY_DRY → DEFICIT → IRRIGATE_ON",
        "metadata": {
          "description": "Tracks progressive substrate drying from adequate moisture through deficit. The MOIST+ initial state primes the sequence before DRY can arm, ensuring transient low readings don't trigger false irrigation.",
          "path": "MOIST+ → DRY → VERY_DRY → DEFICIT → output[1,0,0,0]",
          "output": "[1,0,0,0] (IRRIGATE_ON)"
        },
        "vectors": [
          {
            "id": "ag-irr-moist",
            "elements": [
              {
                "value": 0.45,
                "threshold": 0.5
              },
              {
                "value": 0.35,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.25,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "MOIST",
              "description": "MOIST+ — substrate near field capacity; flow nominal; healthy runoff fraction. isInitial A*A = A+.",
              "moisture_range": "0.38–0.52 (adequate)",
              "runoff_range": "0.15–0.35 (healthy drainage)"
            },
            "nextVectorIds": [
              "ag-irr-moist",
              "ag-irr-dry"
            ]
          },
          {
            "id": "ag-irr-dry",
            "elements": [
              {
                "value": 0.3,
                "threshold": 0.5
              },
              {
                "value": 0.22,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "DRY",
              "description": "DRY — moisture declining; reduced runoff indicates substrate drying out.",
              "moisture_range": "0.22–0.38",
              "runoff_range": "0.05–0.15"
            },
            "nextVectorIds": [
              "ag-irr-very-dry"
            ]
          },
          {
            "id": "ag-irr-very-dry",
            "elements": [
              {
                "value": 0.18,
                "threshold": 0.5
              },
              {
                "value": 0.12,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.05,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "VERY_DRY",
              "description": "VERY_DRY — critical moisture depletion; plants entering water stress.",
              "moisture_range": "0.10–0.22"
            },
            "nextVectorIds": [
              "ag-irr-deficit"
            ]
          },
          {
            "id": "ag-irr-deficit",
            "elements": [
              {
                "value": 0.08,
                "threshold": 0.5
              },
              {
                "value": 0.05,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.02,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "DEFICIT",
              "description": "DEFICIT — severe water deficit; fires IRRIGATE_ON immediately.",
              "moisture_range": "0.0–0.12 (wilting point)"
            },
            "outputVectors": [
              {
                "id": "ag-irr-irrigate-output",
                "vector": [
                  1,
                  0,
                  0,
                  0
                ],
                "metadata": {
                  "description": "IRRIGATE_ON: open irrigation valve and run pump at [24:28]",
                  "action": "Immediate irrigation; downstream growth monitor registers water-stress state"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "ag-irrig-waterlog",
        "name": "Waterlogging Escalation: WET_WATCH+ → WET → SATURATED → WATERLOGGED → DRAIN_ALERT",
        "metadata": {
          "description": "Detects progressive waterlogging from elevated moisture through saturation. Prevents root rot by triggering drain alerts before anaerobic conditions develop.",
          "path": "WET_WATCH+ → WET → SATURATED → WATERLOGGED → output[0,1,0,0]",
          "output": "[0,1,0,0] (DRAIN_ALERT)"
        },
        "vectors": [
          {
            "id": "ag-irr-wet-watch",
            "elements": [
              {
                "value": 0.62,
                "threshold": 0.5
              },
              {
                "value": 0.65,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.58,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "WET_WATCH",
              "description": "WET_WATCH+ — slightly above field capacity; elevated runoff indicates over-irrigation starting. isInitial A*A = A+.",
              "moisture_range": "0.55–0.70",
              "runoff_range": "0.50–0.65 (excessive)"
            },
            "nextVectorIds": [
              "ag-irr-wet-watch",
              "ag-irr-wet"
            ]
          },
          {
            "id": "ag-irr-wet",
            "elements": [
              {
                "value": 0.75,
                "threshold": 0.5
              },
              {
                "value": 0.72,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.7,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "WET",
              "description": "WET — substrate retaining excess water; drain channels may be restricted.",
              "moisture_range": "0.68–0.82"
            },
            "nextVectorIds": [
              "ag-irr-saturated"
            ]
          },
          {
            "id": "ag-irr-saturated",
            "elements": [
              {
                "value": 0.87,
                "threshold": 0.5
              },
              {
                "value": 0.85,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.82,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "SATURATED",
              "description": "SATURATED — near-total pore saturation; oxygen displacement beginning.",
              "moisture_range": "0.80–0.92"
            },
            "nextVectorIds": [
              "ag-irr-waterlogged"
            ]
          },
          {
            "id": "ag-irr-waterlogged",
            "elements": [
              {
                "value": 0.95,
                "threshold": 0.5
              },
              {
                "value": 0.93,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.92,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "WATERLOGGED",
              "description": "WATERLOGGED — anaerobic root zone conditions; fires DRAIN_ALERT.",
              "moisture_range": "0.92–1.00 (fully saturated)"
            },
            "outputVectors": [
              {
                "id": "ag-irr-drain-output",
                "vector": [
                  0,
                  1,
                  0,
                  0
                ],
                "metadata": {
                  "description": "DRAIN_ALERT: open drain valve; halt irrigation pump at [24:28]",
                  "action": "Emergency drain; downstream growth monitor registers waterlogging state"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "ag-irrig-balanced",
        "name": "Balanced Irrigation: BALANCED+ → FLOW_OK",
        "metadata": {
          "description": "Fires FLOW_OK when substrate moisture, flow rate, and runoff fraction are all within optimal ranges. Provides continuous healthy-cycle signal to downstream plant growth monitors.",
          "pattern": "BALANCED+",
          "output": "[0,0,0,1] (FLOW_OK)"
        },
        "vectors": [
          {
            "id": "ag-irr-balanced",
            "elements": [
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.45,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.28,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "BALANCED",
              "description": "BALANCED+ — moisture at field capacity, flow nominal, healthy 20–30% runoff fraction. Fires FLOW_OK each cycle conditions are met.",
              "moisture_range": "0.44–0.56 (field capacity band)",
              "runoff_range": "0.20–0.35 (ideal drainage)"
            },
            "outputVectors": [
              {
                "id": "ag-irr-ok-output",
                "vector": [
                  0,
                  0,
                  0,
                  1
                ],
                "metadata": {
                  "description": "FLOW_OK: optimal irrigation cycle active at [24:28]",
                  "action": "Downstream AgPlantGrowthCycleMonitor registers healthy water state"
                }
              }
            ]
          }
        ]
      }
    ],
    "inputSequences": [
      {
        "name": "Dry-Down Cycle and Recovery",
        "pattern": "8-step: MOIST→MOIST→DRY→VERY_DRY→DEFICIT→(irrigate)→MOIST→BALANCED",
        "description": "Substrate dries between irrigation events; IRRIGATE_ON fires at DEFICIT; system recovers to BALANCED.",
        "vectors": [
          [
            0.46,
            0.36,
            0.5,
            0.26
          ],
          [
            0.44,
            0.33,
            0.5,
            0.22
          ],
          [
