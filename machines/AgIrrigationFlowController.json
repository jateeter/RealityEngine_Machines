{
  "version": "1.0.0",
  "machine": {
    "name": "Ag Irrigation Flow Controller",
    "description": "Monitors substrate moisture, flow rate, and electrical conductivity to detect irrigation deficits and waterlogging in hydroponic and soil-based indoor systems. Two escalation sequences (DRY_DOWN and WATERLOG) plus a BALANCED signal for optimal drainage cycles. Upstream: raw flow sensors at [4:8]. Downstream: AgPlantGrowthCycleMonitor reads output at [24:28].",
    "metadata": {
      "category": "agriculture",
      "domain": "Agriculture — Water Management / Irrigation",
      "author": "Reality Engine",
      "outputSpace": "4D binary at [24:28]: [1,0,0,0]=IRRIGATE_ON, [0,1,0,0]=DRAIN_ALERT, [0,0,1,0]=EC_ALERT, [0,0,0,1]=FLOW_OK",
      "tags": [
        "ag-irrigation-flow-controller",
        "agriculture",
        "agriculture-generated",
        "agriculture-water-management-irrigation",
        "ces-sequences",
        "ces-sequences-3",
        "hydroponics",
        "indoor-growing",
        "input-sequences",
        "input-sequences-1",
        "irrigation",
        "kleene-plus",
        "moisture",
        "startup-loadable",
        "water-management"
      ],
      "sequenceCount": 3,
      "sensorNormalization": {
        "soil_moisture_norm": "0.0=bone dry, 0.5=optimal field capacity (60% WHC), 1.0=fully saturated",
        "flow_rate_norm": "0.0=no flow, 0.5=nominal irrigation rate, 1.0=max pump capacity",
        "substrate_ec_norm": "0.0=distilled water, 0.5=2.0 mS/cm (target), 1.0=4.0+ mS/cm (toxic)",
        "runoff_ratio_norm": "0.0=zero runoff, 0.5=15–20% (healthy drainage), 1.0=100% runoff"
      },
      "downstreamMachine": "AgPlantGrowthCycleMonitor (reads [24:28])",
      "tagging": {
        "schemaVersion": "1.0.0",
        "managedBy": "scripts/manage_machine_tags.mjs",
        "primaryDomain": "agriculture",
        "domainTags": [
          "agriculture",
          "irrigation",
          "water-management"
        ],
        "family": "ag-irrigation-flow-controller",
        "machineCode": "ag-irrigation-flow-controller",
        "capabilityTags": [],
        "workflowTags": [
          "agriculture-generated",
          "agriculture-water-management-irrigation",
          "hydroponics",
          "indoor-growing",
          "kleene-plus",
          "moisture"
        ],
        "integrationTags": [],
        "validationTags": [
          "ces-sequences",
