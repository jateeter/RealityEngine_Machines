            0.5,
            0.05
          ],
          [
            0.08,
            0.05,
            0.5,
            0.02
          ],
          [
            0.52,
            0.75,
            0.5,
            0.35
          ],
          [
            0.48,
            0.48,
            0.5,
            0.28
          ],
          [
            0.5,
            0.45,
            0.5,
            0.27
          ]
        ],
        "metadata": {
          "scenario": "dry-down-irrigation-recovery",
          "expectedOutputs": {
            "steps_1_2": "FLOW_OK fires [0,0,0,1]",
            "steps_3_4": "no output (DRY/VERY_DRY intermediate)",
            "step_5": "IRRIGATE_ON fires [1,0,0,0]",
            "steps_7_8": "FLOW_OK fires [0,0,0,1]"
          }
        }
      }
    ],
    "matchAlgorithm": "gte"
  }
