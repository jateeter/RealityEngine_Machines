{
  "version": "1.0.0",
  "machine": {
    "name": "Fall Detection",
    "description": "Resilient fall classifier. Each candidate fall must survive a multi-step critical event sequence that validates duration AND impact strength before a determination is broadcast to listeners. RED (emergency dispatch) requires six consecutive ticks of progressive evidence: motion onset → sustained motion → severe motion → post-impact stillness onset → sustained stillness → very-sustained stillness. AMBER tiers report less-certain patterns (recovered stumbles, recovered impacts, sustained instability) without escalating to emergency.",
    "metadata": {
      "category": "health-personal",
      "domain": "wellness",
      "author": "Reality Engine",
      "created": "2026-04-21T00:00:00Z",
      "lastRevised": "2026-05-08T00:00:00Z",
      "workflow": "in-home-fall-detection",
      "eventSpace": "2D ordinal: input[0] = motion-progression (0=none, 1=brief, 2=sustained, 3=severe); input[1] = stillness-progression (0=moving, 1=brief-still, 2=sustained-still, 3=very-sustained-still)",
      "outputSpace": "2D ordinal: output[0] = tier (0=GREEN, 1=AMBER-low, 2=AMBER-med, 3=AMBER-high, 4=RED); output[1] = confidence (0=very-low … 3=high)",
      "designNotes": "All multi-step transitions use Hamming distance 1 — each tick changes exactly one element. The sensor pre-aggregator is responsible for translating raw IMU samples into the 0..3 ordinal levels (typically: brief = 1 tick of signal, sustained = 3 ticks, severe = 5+ ticks). RED is reserved for the only sequence that can prove an impact preceded sustained stillness; slow-fall (collapse without struggle) gets RED at lower confidence after 3 ticks of monotonic stillness escalation.",
      "tags": [
        "anomaly-detection",
        "ces-sequences",
        "ces-sequences-7",
        "elder-care",
        "fall-detection",
        "health-personal",
        "in-home-monitoring",
        "input-sequences",
        "input-sequences-7",
        "multi-step-validation",
        "security",
        "startup-loadable",
        "trigger",
        "wellness"
      ],
      "sequenceCount": 7,
      "severity": "life-safety",
      "governance": {
        "schemaVersion": "1.0.0",
        "ownerTeam": "patient-safety-on-call",
        "runbook": "https://runbooks.example.org/patient-safety/fall-detection",
        "escalationPolicy": "pagerduty:patient-safety-tier-1",
        "contact": {
          "primary": "patient-safety-team@example.org",
          "secondary": "clinical-engineering-oncall@example.org"
        },
        "sla": {
          "ok": null,
          "info": null,
          "warning": 1800,
          "error": 60
        },
        "notes": "RED outputs page primary on-call within 60s. AMBER warnings page within 30min to caregiver-facing channel. Sole source of truth — DO NOT override paging policy elsewhere."
      },
      "triggerConfig": {
        "endpoint": "http://localhost:4000/graphql",
        "template": "examples/triggers/graphql_trigger_template.py",
        "processId": "FALL-DETECTION",
        "processName": "Fall Detection",
        "rules": [
          {
            "sequenceId": "fall-nominal",
            "outputMatches": [
              0,
              3
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "ok",
            "description": "Nominal monitoring — no fall indication"
          },
          {
            "sequenceId": "fall-stumble-recovered",
            "outputMatches": [
              1,
              2
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "info",
            "description": "Brief stumble + recovery (1 tick of motion, then nominal) — log only"
          },
          {
            "sequenceId": "fall-sustained-instability",
            "outputMatches": [
              2,
              2
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "Three ticks of progressively worsening motion without recovery — caregiver should monitor"
          },
          {
            "sequenceId": "fall-impact-recovered",
            "outputMatches": [
              3,
              3
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "Severe motion sustained then recovered — caregiver check-in recommended"
          },
          {
            "sequenceId": "fall-confirmed",
            "outputMatches": [
              4,
              3
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "Confirmed fall: motion onset → sustained → severe → impact stillness over six ticks. Dispatch caregiver / emergency contact.",
            "governance": {
              "slaSeconds": 30,
              "runbook": "https://runbooks.example.org/patient-safety/fall-detection#confirmed-red",
              "ownerTeam": "patient-safety-on-call-tier-1"
            }
          },
          {
            "sequenceId": "fall-slow-collapse",
            "outputMatches": [
              4,
              2
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "Sudden onset of stillness escalating over three ticks without preceding motion — possible syncope / silent collapse",
            "governance": {
              "slaSeconds": 45,
              "runbook": "https://runbooks.example.org/patient-safety/fall-detection#slow-collapse"
            }
          },
          {
            "sequenceId": "fall-intentional-lying",
            "outputMatches": [
              0,
              2
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "Stillness reached without preceding motion or impact — likely intentional lying down (sleep / rest)"
          }
        ]
      },
