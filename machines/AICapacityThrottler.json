            "sequenceId": "aict-capacity-escalation",
            "outputMatches": [
              0,
              0,
              0,
              0,
              1,
              0
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "Action: Rate-limit new inference requests to prevent queue overflow"
          },
          {
            "sequenceId": "aict-capacity-escalation",
            "outputMatches": [
              0,
              0,
              0,
              1,
              0,
              0
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "Compute capacity OVERLOADED — OOM risk, SLO violations imminent"
          },
          {
            "sequenceId": "aict-capacity-escalation",
            "outputMatches": [
              0,
              0,
              0,
              0,
              1,
              0
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "Action: Hard throttle all inference, reject new requests"
          },
          {
            "sequenceId": "aict-capacity-escalation",
            "outputMatches": [
              0,
              0,
              0,
              0,
              0,
              1
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "Action: Immediately preempt and shed low-priority batch training jobs"
          },
          {
            "sequenceId": "aict-memory-pressure",
