            "sequenceId": "aict-capacity-escalation",
            "outputMatches": [
              1,
              0,
              0,
              0,
              0,
              0
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "Compute capacity AVAILABLE — accepting new inference and training jobs"
          },
          {
            "sequenceId": "aict-capacity-escalation",
            "outputMatches": [
              0,
              1,
              0,
              0,
              0,
              0
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "Compute capacity BUSY — high utilization, monitor queue depth"
          },
          {
            "sequenceId": "aict-capacity-escalation",
            "outputMatches": [
              0,
              0,
              1,
              0,
              0,
              0
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "Compute capacity SATURATED — queue growing, inference latency increasing"
