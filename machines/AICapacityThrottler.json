              0,
              0,
              0,
              0,
              0,
              1
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "Action: Shed batch jobs to reclaim GPU memory before OOM kills active inference"
          }
        ]
      }
