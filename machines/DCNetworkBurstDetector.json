                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "NORMAL_FLOW",
              "description": "Network traffic at baseline \u2014 fires [0,1] reset signal on every matching cycle (A*A = A+: at least one matching cycle required to produce output)",
              "role": "continuous-reset-plus",
              "bandwidth_range": "0.05\u20130.35 (same as BASELINE)",
              "packet_loss_range": "0.00\u20130.10 (same as BASELINE)"
            },
            "outputVectors": [
