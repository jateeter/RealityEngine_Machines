    },
    "sequences": [
      {
        "id": "dc-network-escalation",
        "name": "Network Escalation: BASELINE+ \u2192 ELEVATED+ \u2192 BURST \u2192 CONGESTION+ \u2192 OVERFLOW",
        "metadata": {
          "description": "5-stage network escalation from baseline traffic to catastrophic overflow. All isInitial states implement A*A = A+ semantics.",
          "path": "BASELINE+ \u2192 ELEVATED+ \u2192 BURST \u2192 CONGESTION+ \u2192 OVERFLOW",
          "output": "[1,0] (NETWORK ALARM)"
        },
        "vectors": [
          {
            "id": "dc-net-esc-baseline",
            "elements": [
              {
                "value": 0.2,
                "threshold": 0.5
              },
              {
                "value": 0.05,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "BASELINE",
              "description": "BASELINE+ (= BASELINE*BASELINE, A*A) \u2014 one or more baseline readings required before ELEVATED is armed. isInitial provides the self-loop (A*); the mandatory match (A) activates ELEVATED via nextVectorIds.",
              "role": "kleene-plus-initial",
              "bandwidth_range": "0.05\u20130.35 (5%\u201335% utilization)",
              "packet_loss_range": "0.00\u20130.10 (0%\u20131% loss)",
              "kleeneOperator": "+"
            },
            "nextVectorIds": [
              "dc-net-esc-baseline",
              "dc-net-esc-elevated"
            ]
          },
          {
            "id": "dc-net-esc-elevated",
            "elements": [
              {
                "value": 0.55,
                "threshold": 0.5
              },
              {
                "value": 0.15,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "ELEVATED",
              "description": "ELEVATED+ \u2014 sustained elevated traffic; one or more elevated readings required",
              "role": "kleene-plus",
              "bandwidth_range": "0.43\u20130.67 (43%\u201367% utilization)",
              "packet_loss_range": "0.05\u20130.25 (0.5%\u20132.5% loss)",
              "kleeneOperator": "+"
            },
            "nextVectorIds": [
              "dc-net-esc-elevated",
              "dc-net-esc-burst"
            ]
          },
          {
            "id": "dc-net-esc-burst",
            "elements": [
              {
                "value": 0.75,
                "threshold": 0.5
              },
              {
                "value": 0.3,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "BURST",
              "description": "BURST \u2014 peak traffic burst; mandatory single transition before sustained congestion",
              "role": "required-transition",
              "bandwidth_range": "0.67\u20130.83 (67%\u201383% utilization)",
              "packet_loss_range": "0.18\u20130.42 (1.8%\u20134.2% loss)",
              "semantics": "Non-initial transitional (no self-loop): exactly one BURST reading advances to CONGESTION. Requires observable burst peak before declaring congestion."
            },
            "nextVectorIds": [
              "dc-net-esc-congestion"
            ]
          },
          {
            "id": "dc-net-esc-congestion",
            "elements": [
              {
                "value": 0.88,
                "threshold": 0.5
              },
              {
                "value": 0.55,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "CONGESTION",
              "description": "CONGESTION+ \u2014 sustained network congestion with significant packet loss",
              "role": "kleene-plus",
              "bandwidth_range": "0.82\u20130.94 (82%\u201394% utilization)",
              "packet_loss_range": "0.45\u20130.65 (4.5%\u20136.5% loss)",
              "kleeneOperator": "+"
            },
            "nextVectorIds": [
              "dc-net-esc-congestion",
              "dc-net-esc-overflow"
            ]
          },
          {
            "id": "dc-net-esc-overflow",
            "elements": [
              {
                "value": 0.97,
                "threshold": 0.5
              },
              {
                "value": 0.85,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "OVERFLOW",
              "description": "OVERFLOW \u2014 link saturation with severe packet loss; fires network alarm",
              "role": "terminal",
              "bandwidth_range": "0.93\u20131.00 (>93% utilization)",
              "packet_loss_range": "0.75\u20130.95 (7.5%\u20139.5%+ loss)"
            },
            "outputVectors": [
              {
                "id": "dc-net-esc-alarm-output",
                "vector": [
                  1,
                  0
                ],
                "metadata": {
                  "description": "NETWORK OVERFLOW: Alarm signal [1,0] to DCNetworkThrottleFF at [1365:1367]",
                  "severity": "EMERGENCY",
                  "action": "DCNetworkThrottleFF will SET; traffic shaping and rate limiting engaged"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "dc-network-normal-flow",
        "name": "Normal Flow Recovery: NORMAL_FLOW+ \u2192 output[0,1]",
        "metadata": {
          "description": "Fires reset signal [0,1] on every cycle that network traffic is within normal baseline parameters (A*A = A+: one or more matching cycles). Enables DCNetworkThrottleFF to RESET when conditions are normal.",
          "pattern": "NORMAL_FLOW+",
          "output": "[0,1] (NETWORK NORMAL)"
        },
        "vectors": [
