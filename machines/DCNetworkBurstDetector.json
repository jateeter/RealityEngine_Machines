{
  "version": "1.0.0",
  "machine": {
    "name": "DC Network Burst Detector",
    "description": "Monitors network bandwidth utilization and packet loss to detect burst traffic and congestion events. Implements the regular expression BASELINE+ \u2192 ELEVATED+ \u2192 BURST \u2192 CONGESTION+ \u2192 OVERFLOW \u2192 [alarm]. A concurrent NORMAL_FLOW+ sequence fires the reset signal when network conditions are nominal.",
    "metadata": {
      "category": "data-center",
      "domain": "Data Center \u2014 Network / Burst Detection",
      "author": "Reality Engine",
      "created": "2026-02-27T00:00:00Z",
      "eventSpace": "4D continuous sensor vector at [1348:1352]: [bandwidth_util_norm, packet_loss_norm, latency_norm, queue_depth_norm]",
      "outputSpace": "2D binary at [1365:1367]: [1,0]=NETWORK_ALARM, [0,1]=NETWORK_NORMAL",
      "tags": [
        "anomaly-detection",
        "burst-detection",
        "ces-sequences",
        "ces-sequences-2",
        "data-center",
        "data-center-network-burst-detection",
        "dc-network-burst-detector",
        "dcnetwork-burst-detector",
        "input-sequences",
        "input-sequences-1",
        "monitoring",
        "network",
        "startup-loadable"
      ],
      "sequenceCount": 2,
      "downstreamMachine": "DCNetworkThrottleFF (reads [1365:1367])",
      "regularExpression": {
        "escalation": "BASELINE+ \u2192 ELEVATED+ \u2192 BURST \u2192 CONGESTION+ \u2192 OVERFLOW \u2192 output[1,0]",
        "recovery": "NORMAL_FLOW+ \u2192 output[0,1]",
        "combined": "Detects network saturation events that require traffic shaping. Requires sustained elevated traffic (ELEVATED+) before BURST, and sustained congestion (CONGESTION+) before OVERFLOW. This prevents false alarms from brief micro-bursts.",
        "isInitialNote": "BASELINE and NORMAL_FLOW are isInitial vectors implementing A*A = A+. At least one baseline reading is required to arm ELEVATED; at least one safe-flow reading is required to produce the reset output. There is no mechanism to advance the escalation sequence or generate output without a matching sensor observation."
      },
      "sensorNormalization": {
        "bandwidth_util_norm": "0.0 = 0% utilization, 1.0 = 100% link capacity",
        "packet_loss_norm": "0.0 = 0% loss, 1.0 = severe loss (>10%)",
        "latency_norm": "wildcard (don't care \u2014 value=0.5, tolerance=0.5)",
        "queue_depth_norm": "wildcard (don't care \u2014 value=0.5, tolerance=0.5)"
      },
      "singleTransitionAssumption": {
        "required": false,
        "scope": "continuous sensor space \u2014 STA not applicable as defined for binary vectors",
        "compliant": true,
        "notes": "Same continuous-space STA analog as DCThermalEscalation: gradual bandwidth progression through bands. Sudden traffic bursts that skip intermediate stages (e.g., BASELINE directly to OVERFLOW) will not trigger the alarm \u2014 consistent with the design requirement that genuine overflow events follow observable escalation patterns. BASELINE is isInitial (A*A = A+): at least one BASELINE reading is required to arm ELEVATED."
      },
