        "processId": "DCNETWORKBURSTDETECTOR",
        "processName": "DC Network Burst Detector",
        "rules": [
          {
            "sequenceId": "dc-network-escalation",
            "outputMatches": [
              1,
              0
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "NETWORK OVERFLOW: Alarm signal [1,0] to DCNetworkThrottleFF at [1365:1367]"
          },
          {
            "sequenceId": "dc-network-normal-flow",
            "outputMatches": [
              0,
              1
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "NETWORK NORMAL: Reset signal [0,1] to DCNetworkThrottleFF at [1365:1367]"
          }
        ]
      }
