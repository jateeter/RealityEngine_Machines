                ],
                "metadata": {
                  "description": "NETWORK NORMAL: Reset signal [0,1] to DCNetworkThrottleFF at [1365:1367]",
                  "severity": "INFO",
                  "action": "DCNetworkThrottleFF will RESET; normal traffic flow"
                }
              }
            ]
          }
        ]
      }
    ],
