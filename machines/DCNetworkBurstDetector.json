    "arbiterRule": "PASSTHROUGH",
    "perceptualMapping": {
      "input": {
        "offset": 1348,
        "length": 4
      },
      "output": {
        "offset": 1365,
        "length": 2
      },
      "bitsPerElement": 8
    },
    "sequences": [
      {
        "id": "dc-network-escalation",
        "name": "Network Escalation: BASELINE+ → ELEVATED+ → BURST → CONGESTION+ → OVERFLOW",
        "metadata": {
          "description": "5-stage network escalation from baseline traffic to catastrophic overflow. All isInitial states implement A*A = A+ semantics.",
          "path": "BASELINE+ → ELEVATED+ → BURST → CONGESTION+ → OVERFLOW",
          "output": "[1,0] (NETWORK ALARM)"
        },
        "vectors": [
          {
            "id": "dc-net-esc-baseline",
            "elements": [
              {
                "value": 0.2,
                "threshold": 0.5
              },
              {
                "value": 0.05,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "BASELINE",
              "description": "BASELINE+ (= BASELINE*BASELINE, A*A) — one or more baseline readings required before ELEVATED is armed. isInitial provides the self-loop (A*); the mandatory match (A) activates ELEVATED via nextVectorIds.",
              "role": "kleene-plus-initial",
              "bandwidth_range": "0.05–0.35 (5%–35% utilization)",
              "packet_loss_range": "0.00–0.10 (0%–1% loss)",
              "kleeneOperator": "+"
            },
            "nextVectorIds": [
              "dc-net-esc-baseline",
              "dc-net-esc-elevated"
            ]
          },
          {
            "id": "dc-net-esc-elevated",
            "elements": [
              {
                "value": 0.55,
                "threshold": 0.5
              },
              {
                "value": 0.15,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "ELEVATED",
              "description": "ELEVATED+ — sustained elevated traffic; one or more elevated readings required",
              "role": "kleene-plus",
              "bandwidth_range": "0.43–0.67 (43%–67% utilization)",
              "packet_loss_range": "0.05–0.25 (0.5%–2.5% loss)",
              "kleeneOperator": "+"
            },
            "nextVectorIds": [
              "dc-net-esc-elevated",
              "dc-net-esc-burst"
            ]
          },
          {
            "id": "dc-net-esc-burst",
            "elements": [
              {
                "value": 0.75,
                "threshold": 0.5
              },
              {
                "value": 0.3,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "BURST",
              "description": "BURST — peak traffic burst; mandatory single transition before sustained congestion",
              "role": "required-transition",
              "bandwidth_range": "0.67–0.83 (67%–83% utilization)",
              "packet_loss_range": "0.18–0.42 (1.8%–4.2% loss)",
              "semantics": "Non-initial transitional (no self-loop): exactly one BURST reading advances to CONGESTION. Requires observable burst peak before declaring congestion."
            },
            "nextVectorIds": [
              "dc-net-esc-congestion"
            ]
          },
          {
            "id": "dc-net-esc-congestion",
            "elements": [
              {
                "value": 0.88,
                "threshold": 0.5
              },
              {
                "value": 0.55,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "CONGESTION",
              "description": "CONGESTION+ — sustained network congestion with significant packet loss",
              "role": "kleene-plus",
              "bandwidth_range": "0.82–0.94 (82%–94% utilization)",
              "packet_loss_range": "0.45–0.65 (4.5%–6.5% loss)",
              "kleeneOperator": "+"
            },
            "nextVectorIds": [
              "dc-net-esc-congestion",
              "dc-net-esc-overflow"
            ]
          },
          {
            "id": "dc-net-esc-overflow",
            "elements": [
              {
                "value": 0.97,
                "threshold": 0.5
              },
              {
                "value": 0.85,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              },
              {
                "value": 0.5,
                "threshold": 0.5
              }
            ],
            "isInitial": false,
            "metadata": {
              "name": "OVERFLOW",
              "description": "OVERFLOW — link saturation with severe packet loss; fires network alarm",
              "role": "terminal",
              "bandwidth_range": "0.93–1.00 (>93% utilization)",
              "packet_loss_range": "0.75–0.95 (7.5%–9.5%+ loss)"
            },
            "outputVectors": [
              {
                "id": "dc-net-esc-alarm-output",
                "vector": [
                  1,
                  0
                ],
                "metadata": {
                  "description": "NETWORK OVERFLOW: Alarm signal [1,0] to DCNetworkThrottleFF at [1365:1367]",
                  "severity": "EMERGENCY",
                  "action": "DCNetworkThrottleFF will SET; traffic shaping and rate limiting engaged"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "dc-network-normal-flow",
        "name": "Normal Flow Recovery: NORMAL_FLOW+ → output[0,1]",
        "metadata": {
          "description": "Fires reset signal [0,1] on every cycle that network traffic is within normal baseline parameters (A*A = A+: one or more matching cycles). Enables DCNetworkThrottleFF to RESET when conditions are normal.",
          "pattern": "NORMAL_FLOW+",
          "output": "[0,1] (NETWORK NORMAL)"
        },
        "vectors": [
