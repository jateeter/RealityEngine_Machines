            ],
            "isInitial": true,
            "metadata": {
              "name": "NORMAL_FLOW",
              "description": "Network traffic at baseline — fires [0,1] reset signal on every matching cycle (A*A = A+: at least one matching cycle required to produce output)",
              "role": "continuous-reset-plus",
              "bandwidth_range": "0.05–0.35 (same as BASELINE)",
              "packet_loss_range": "0.00–0.10 (same as BASELINE)"
            },
            "outputVectors": [
