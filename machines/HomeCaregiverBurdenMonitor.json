        "metadata": {
          "description": "Tracks caregiver burden escalation driven by simultaneous pediatric health and developmental challenges. When both upstream machines signal concern simultaneously, caregiver coping is overwhelmed — especially in single-parent, low-income households with no respite network. The COPING+ baseline requires at least one confirmed adequate period before burnout escalation can arm.",
          "path": "COPING+ → STRAINED → HIGH_BURDEN_STATE → output[1,0,0,0]",
          "output": "[1,0,0,0] (CAREGIVER_BURNOUT)"
        },
