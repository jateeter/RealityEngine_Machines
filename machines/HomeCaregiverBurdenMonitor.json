{
  "version": "1.0.0",
  "machine": {
    "name": "Home Caregiver Burden Monitor",
    "description": "Integration machine that reads combined output signals from the Pediatric Nutrition Monitor [2003:2007] and the Child Development Monitor [2007:2011] to assess caregiver burden driven by child health challenges. Child nutritional problems and developmental delays are the primary pediatric-driven stressors for at-home caregivers in low-income settings. Caregiver burnout reduces care quality across all household members and is a leading predictor of preventable pediatric ED visits. Output at [2031:2035] is available to downstream care coordination systems.",
    "metadata": {
      "category": "health-personal",
      "domain": "Home Health — Caregiver Support / Burden Assessment",
      "author": "Reality Engine",
      "outputSpace": "4D binary at [2031:2035]: [1,0,0,0]=CAREGIVER_BURNOUT, [0,1,0,0]=HIGH_BURDEN, [0,0,1,0]=MODERATE_BURDEN, [0,0,0,1]=CAREGIVER_COPING",
      "tags": [
        "burden-assessment",
        "caregiver-burden",
        "caregiver-burnout",
        "caregiver-support",
        "ces-sequences",
        "ces-sequences-3",
        "child-health",
        "health-personal",
        "home-caregiver-burden-monitor",
        "home-health",
        "home-health-caregiver-support-burden-assessment",
        "input-sequences",
        "input-sequences-1",
        "kleene-plus",
        "low-income",
        "pediatric",
        "startup-loadable"
      ],
      "sequenceCount": 3,
      "populationFocus": "Primary caregivers of children with health or developmental challenges; single parents; low-income households with limited respite support",
      "sensorNormalization": {
        "nutrition_alert_signal_norm": "0.0=[1,0,0,0] GROWTH_ALERT from PedNutrition (bit 350), 0.5=[0,0,1,0] MICRONUTRIENT_CONCERN (bit 352), 1.0=[0,0,0,1] NUTRITION_OK (bit 353)",
        "development_alert_signal_norm": "0.0=[1,0,0,0] REFERRAL_NEEDED from ChildDev (bit 354), 0.5=[0,1,0,0] SOCIAL_DEVELOPMENTAL_CONCERN (bit 355), 1.0=[0,0,0,1] DEVELOPMENT_OK (bit 357)",
        "caregiver_stress_norm": "0.0=caregiver expressing burnout, inability to cope; household management failing, 0.5=managing under stress; help sought but not adequate, 1.0=caregiver managing adequately with support",
        "respite_access_norm": "0.0=zero respite support (no family, no programs, no childcare), 0.5=limited respite (one source available but insufficient), 1.0=adequate respite network; regular relief available"
      },
      "upstreamMachines": [
        "PediatricNutritionMonitor (output [2003:2007])",
        "ChildDevelopmentMonitor (output [2007:2011])"
      ],
