{
  "version": "1.0.0",
  "machine": {
    "name": "NewPatientInflow",
    "description": "New patient evaluation workflow for an elder care assisted living organization. Detects structured intake sequences and classifies each candidate as ACCEPTED or PROVISIONAL_REJECT.",
    "metadata": {
      "category": "health-personal",
      "author": "Reality Engine",
      "created": "2026-04-09T00:00:00Z",
      "domain": "Healthcare Intake \u2014 Assisted Living",
      "eventSpace": "8D binary evaluation space: [CONTACT, PRESCREENED, MEDICAL_CLEAR, FUNCTIONAL_FIT, FINANCIAL_CLEAR, VACANCY, CONSENT, BARRIER]",
      "outputSpace": "8D one-hot decision space: [ACCEPTED, PROVISIONAL_REJECT, _, _, _, _, _, _]",
      "regex": "(CONTACT)+ \u00b7 PRESCREENED \u00b7 (MED_FUNC_CLEAR \u00b7 (FIN_CLEAR \u00b7 (VACANCY_CONF \u00b7 ADMITTED | VACANCY_BARRIER) | FIN_BARRIER) | MED_BARRIER)",
      "dimensions": {
        "D0_CONTACT": "Initial inquiry received from patient or family \u2014 contact event flag",
        "D1_PRESCREENED": "Basic eligibility confirmed: age \u226555, ADL dependency level in scope, referral valid",
        "D2_MEDICAL_CLEAR": "Clinical assessment complete and within facility care scope (not requiring hospital-level acuity)",
        "D3_FUNCTIONAL_FIT": "Activities of Daily Living (ADL) assessment passed; mobility/cognitive level within supported range",
        "D4_FINANCIAL_CLEAR": "Insurance verification approved OR private-pay qualification confirmed",
        "D5_VACANCY": "Appropriate room or memory-care unit currently available",
        "D6_CONSENT": "Family/guardian consent obtained, care plan reviewed and signed",
        "D7_BARRIER": "Hard-stop disqualification flag: set when any evaluation stage fails"
      },
      "vectorEncoding": {
        "H": 0.9,
        "L": 0.1,
        "threshold": 0.5,
        "semantics": "GTE binary: value>=threshold \u2192 HIGH (event present), value<threshold \u2192 LOW (event absent). Barrier path sets D7=H while clearing the failed dimension."
      },
      "inputVectors": {
        "INQUIRY": "[H,L,L,L,L,L,L,L] \u2014 new contact event only",
        "PRESCREENED": "[H,H,L,L,L,L,L,L] \u2014 contact + eligibility confirmed",
        "MED_FUNC_CLEAR": "[H,H,H,H,L,L,L,L] \u2014 contact + prescreened + medical + functional all pass",
        "MED_BARRIER": "[H,H,L,L,L,L,L,H] \u2014 contact + prescreened, medical FAILED, barrier raised",
        "FIN_CLEAR": "[H,H,H,H,H,L,L,L] \u2014 medical/functional pass + financial verified",
        "FIN_BARRIER": "[H,H,H,H,L,L,L,H] \u2014 medical/functional pass, financial FAILED, barrier raised",
        "VACANCY_CONF": "[H,H,H,H,H,H,L,L] \u2014 full clinical/financial pass + room confirmed",
        "VACANCY_BARRIER": "[H,H,H,H,H,L,L,H] \u2014 clinical/financial pass, no room available, barrier raised",
        "ADMITTED": "[H,H,H,H,H,H,H,L] \u2014 all criteria met, consent obtained, care plan signed"
      },
      "singleTransitionAssumption": {
        "required": true,
        "compliant": true,
        "notes": "All valid transitions change exactly one or two binary dimensions per step. INQUIRY\u2192PRESCREENED: HD=1 (D1 L\u2192H). PRESCREENED\u2192MED_FUNC_CLEAR: HD=2 (D2,D3 simultaneously L\u2192H \u2014 medical and functional assessment complete together). All other transitions: HD=1. Barrier transitions diverge by setting D7=H while the failed dimension stays L, maintaining Hamming distance \u22641 from the prior non-barrier state."
      },
