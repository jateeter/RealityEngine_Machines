{
  "version": "1.0.0",
  "machine": {
    "id": "ai-hardware-resilience",
    "name": "AI Hardware Resilience Monitor",
    "description": "Monitors AI infrastructure hardware health — detects disk SMART failures, GPU/CPU memory ECC errors, network packet loss, and hardware fault accumulation to trigger proactive workload evacuation before catastrophic failure.",
    "arbiterRule": "PASSTHROUGH",
    "matchAlgorithm": "gte",
    "perceptualMapping": {
      "input": {
        "offset": 276,
        "length": 4
      },
      "output": {
        "offset": 3923,
        "length": 6
      },
      "bitsPerElement": 8
    },
    "metadata": {
      "category": "ai-services",
      "domain": "AI Infrastructure — Hardware Health / Resilience",
      "tags": [
        "ai-hardware-resilience-monitor",
        "ai-infrastructure",
        "ai-infrastructure-hardware-health-resilience",
        "ai-services",
        "ai-workload",
        "aihardware-resilience",
        "ces-sequences",
        "ces-sequences-2",
        "data-center",
        "ecc",
        "hardware",
        "hardware-health",
        "input-sequences",
        "input-sequences-3",
        "logical-infrastructure",
        "resilience",
        "smart",
        "startup-loadable"
      ],
      "rationale": "Disk SMART, ECC errors, and network fabric health are physical data-center hardware concerns.",
      "eventSpace": "4D continuous fault severity vector at [276:280]: [disk_fault_score, memory_error_rate, network_packet_loss, hw_fault_accumulation]",
      "outputSpace": "6D status/action at [3923:3929]: [STATUS_HEALTHY, STATUS_WARNING, STATUS_DEGRADED, STATUS_CRITICAL, ACT_EVACUATE_WORKLOADS, ACT_SCHEDULE_MAINTENANCE]",
      "inputDimensions": [
        {
          "index": 0,
          "name": "disk_fault_score",
          "description": "0=all disks healthy (good SMART), 1=critical SMART failures (imminent disk death)"
        },
        {
          "index": 1,
          "name": "memory_error_rate",
          "description": "0=no ECC errors, 1=uncorrectable error storm (DRAM/HBM failing)"
        },
        {
          "index": 2,
          "name": "network_packet_loss",
          "description": "0=no packet loss, 1=severe packet loss (NIC/switch failure)"
        },
        {
          "index": 3,
          "name": "hw_fault_accumulation",
          "description": "0=no hardware faults, 1=fault storm (multiple component failures)"
        }
      ],
      "outputDimensions": [
        {
          "index": 0,
          "name": "STATUS_HEALTHY"
        },
        {
          "index": 1,
          "name": "STATUS_WARNING"
        },
        {
          "index": 2,
          "name": "STATUS_DEGRADED"
        },
        {
          "index": 3,
          "name": "STATUS_CRITICAL"
        },
        {
          "index": 4,
          "name": "ACT_EVACUATE_WORKLOADS"
        },
        {
          "index": 5,
          "name": "ACT_SCHEDULE_MAINTENANCE"
        }
      ],
      "tagging": {
