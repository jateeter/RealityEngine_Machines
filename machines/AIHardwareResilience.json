        "notes": "Auto-backfilled by scripts/backfill-governance.mjs from primaryDomain=\"ai-services\".  Review and tune the routing as the team owning AIHardwareResilience matures."
      },
      "triggerConfig": {
        "processId": "AIHARDWARERESILIENCE",
        "processName": "AI Hardware Resilience Monitor",
        "rules": [
          {
            "sequenceId": "aihr-hw-degradation",
            "outputMatches": [
              1,
              0,
              0,
              0,
              0,
              0
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "Hardware HEALTHY — all SMART indicators nominal, no ECC errors, network clean"
          },
          {
            "sequenceId": "aihr-hw-degradation",
            "outputMatches": [
              0,
              1,
              0,
              0,
              0,
              0
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "Hardware WARNING — early SMART deterioration and elevated ECC error rate"
          },
          {
            "sequenceId": "aihr-hw-degradation",
            "outputMatches": [
              0,
              0,
              1,
              0,
              0,
              0
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "Hardware DEGRADED — multiple components showing failure indicators, reliability compromised"
          },
          {
            "sequenceId": "aihr-hw-degradation",
            "outputMatches": [
              0,
              0,
              0,
              0,
              0,
              1
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "Action: Schedule immediate maintenance window for affected hardware replacement"
          },
          {
            "sequenceId": "aihr-hw-degradation",
            "outputMatches": [
              0,
              0,
              0,
              1,
              0,
              0
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "Hardware CRITICAL — imminent hardware failure, data loss and downtime risk"
          },
          {
            "sequenceId": "aihr-hw-degradation",
            "outputMatches": [
              0,
              0,
              0,
              0,
              1,
              0
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "Action: Immediately evacuate all workloads from affected nodes to healthy hardware"
          },
          {
            "sequenceId": "aihr-hw-degradation",
            "outputMatches": [
              0,
              0,
              0,
              0,
              0,
              1
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "Action: Emergency hardware replacement — pull from production immediately"
          },
          {
            "sequenceId": "aihr-sudden-network-failure",
            "outputMatches": [
              0,
              1,
              0,
              0,
              0,
              0
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "Network fabric FAULT — sudden packet loss spike, likely NIC or switch failure"
          },
          {
            "sequenceId": "aihr-sudden-network-failure",
            "outputMatches": [
              0,
              0,
              0,
              0,
              1,
              0
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "Action: Reroute traffic away from affected network segment, migrate dependent workloads"
          }
        ]
      }
    },
    "sequences": [
      {
        "id": "aihr-hw-degradation",
        "name": "Hardware Degradation Escalation",
        "description": "4-step escalation: HEALTHY → WARNING → DEGRADED → CRITICAL as hardware fault indicators accumulate across disk, memory, network, and fault counters",
        "vectors": [
          {
            "id": "aihr-healthy",
            "isInitial": true,
            "nextVectorIds": [
              "aihr-warning"
            ],
            "elements": [
              {
                "value": 0.05,
                "threshold": 0.5
              },
              {
                "value": 0.08,
                "threshold": 0.5
              },
              {
                "value": 0.04,
                "threshold": 0.5
              },
              {
                "value": 0.06,
                "threshold": 0.5
              }
            ],
            "outputVectors": [
              {
                "id": "aihr-out-healthy",
                "vector": [
                  1,
                  0,
                  0,
                  0,
                  0,
                  0
                ],
                "metadata": {
                  "description": "Hardware HEALTHY — all SMART indicators nominal, no ECC errors, network clean",
                  "severity": "INFO"
                }
              }
            ]
          },
          {
            "id": "aihr-warning",
            "isInitial": false,
            "nextVectorIds": [
              "aihr-degraded"
            ],
            "elements": [
              {
                "value": 0.6,
                "threshold": 0.5
              },
              {
                "value": 0.55,
                "threshold": 0.5
              },
              {
                "value": 0.52,
                "threshold": 0.5
              },
              {
                "value": 0.58,
                "threshold": 0.5
              }
            ],
            "outputVectors": [
              {
                "id": "aihr-out-warning",
                "vector": [
                  0,
                  1,
                  0,
                  0,
                  0,
                  0
                ],
                "metadata": {
                  "description": "Hardware WARNING — early SMART deterioration and elevated ECC error rate",
                  "severity": "WARNING"
                }
              }
            ]
          },
          {
            "id": "aihr-degraded",
            "isInitial": false,
            "nextVectorIds": [
              "aihr-critical"
            ],
            "elements": [
              {
                "value": 0.78,
                "threshold": 0.5
              },
              {
                "value": 0.75,
                "threshold": 0.5
              },
              {
                "value": 0.72,
                "threshold": 0.5
              },
              {
                "value": 0.8,
                "threshold": 0.5
              }
            ],
            "outputVectors": [
              {
                "id": "aihr-out-degraded",
                "vector": [
                  0,
                  0,
                  1,
                  0,
                  0,
                  0
                ],
                "metadata": {
                  "description": "Hardware DEGRADED — multiple components showing failure indicators, reliability compromised",
                  "severity": "CRITICAL"
                }
              },
              {
                "id": "aihr-act-maintenance",
                "vector": [
                  0,
                  0,
                  0,
                  0,
                  0,
                  1
                ],
                "metadata": {
                  "description": "Action: Schedule immediate maintenance window for affected hardware replacement",
                  "severity": "ACTION"
                }
              }
            ]
          },
          {
            "id": "aihr-critical",
            "isInitial": false,
            "nextVectorIds": [],
            "elements": [
              {
                "value": 0.92,
                "threshold": 0.5
              },
              {
                "value": 0.9,
                "threshold": 0.5
              },
              {
                "value": 0.88,
                "threshold": 0.5
              },
              {
                "value": 0.94,
                "threshold": 0.5
              }
            ],
            "outputVectors": [
              {
                "id": "aihr-out-critical",
                "vector": [
                  0,
                  0,
                  0,
                  1,
                  0,
                  0
                ],
                "metadata": {
                  "description": "Hardware CRITICAL — imminent hardware failure, data loss and downtime risk",
                  "severity": "EMERGENCY"
                }
              },
              {
                "id": "aihr-act-evacuate",
                "vector": [
                  0,
                  0,
                  0,
                  0,
                  1,
                  0
                ],
                "metadata": {
                  "description": "Action: Immediately evacuate all workloads from affected nodes to healthy hardware",
                  "severity": "ACTION"
                }
              },
              {
                "id": "aihr-act-maintenance-crit",
                "vector": [
                  0,
                  0,
                  0,
                  0,
                  0,
                  1
                ],
                "metadata": {
                  "description": "Action: Emergency hardware replacement — pull from production immediately",
                  "severity": "ACTION"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "aihr-sudden-network-failure",
        "name": "Sudden Network Fabric Failure",
        "description": "2-step detection: NETWORK_NOMINAL → NETWORK_FAULT — fires when packet loss spikes HIGH while disk and memory health remain LOW (isolated network component failure)",
        "vectors": [
          {
            "id": "aihr-net-nominal",
            "isInitial": true,
            "nextVectorIds": [
              "aihr-net-fault"
            ],
            "elements": [
              {
                "value": 0.08,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              },
              {
                "value": 0.06,
                "threshold": 0.5
              },
              {
                "value": 0.12,
                "threshold": 0.5
              }
            ],
            "outputVectors": []
          },
          {
            "id": "aihr-net-fault",
            "isInitial": false,
            "nextVectorIds": [],
            "elements": [
              {
                "value": 0.08,
                "threshold": 0.5
              },
              {
                "value": 0.1,
                "threshold": 0.5
              },
              {
                "value": 0.85,
                "threshold": 0.5
              },
              {
                "value": 0.12,
                "threshold": 0.5
              }
            ],
            "outputVectors": [
              {
                "id": "aihr-out-net-warn",
                "vector": [
                  0,
                  1,
                  0,
                  0,
                  0,
                  0
                ],
                "metadata": {
                  "description": "Network fabric FAULT — sudden packet loss spike, likely NIC or switch failure",
                  "severity": "WARNING"
                }
              },
              {
                "id": "aihr-act-evacuate-net",
                "vector": [
                  0,
                  0,
                  0,
                  0,
                  1,
                  0
                ],
                "metadata": {
                  "description": "Action: Reroute traffic away from affected network segment, migrate dependent workloads",
                  "severity": "ACTION"
                }
              }
            ]
          }
        ]
      }
    ],
    "inputSequences": [
      {
