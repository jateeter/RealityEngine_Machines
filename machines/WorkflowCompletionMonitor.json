        "metadata": {
          "description": "Detects workflows where both signing and qualification have failed simultaneously — the highest-severity workflow state, where service delivery is fully blocked. Requires COMPLETE+ baseline confirming that a completed workflow state was previously achieved before the block escalation can arm.",
          "path": "COMPLETE+ → PARTIAL → STALLED → output[1,0,0,0]",
          "output": "[1,0,0,0] (WORKFLOW_BLOCKED)"
        },
        "vectors": [
