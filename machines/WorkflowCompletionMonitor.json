{
  "version": "1.0.0",
  "machine": {
    "name": "Workflow Completion Monitor",
    "description": "Integration machine that reads combined output signals from the Document Signing Workflow Monitor [960:964] and the Qualification Verification Monitor [964:968] to detect workflow completion failures — cases where signing and qualification are both required before services can be delivered but one or both remain incomplete. In community services, unclosed workflow loops (unsigned forms + unverified qualifications) create audit risk, delay benefit issuance, and prevent inter-agency coordination. Output at [988:992] is available to downstream care coordination systems.",
    "metadata": {
      "category": "community-services",
      "domain": "Community Services — Workflow Completion / Qualification",
      "author": "Reality Engine",
      "outputSpace": "4D binary at [988:992]: [1,0,0,0]=WORKFLOW_BLOCKED, [0,1,0,0]=WORKFLOW_STALLED, [0,0,1,0]=WORKFLOW_PARTIAL, [0,0,0,1]=WORKFLOW_COMPLETE",
      "tags": [
        "ces-sequences",
        "ces-sequences-3",
        "community-services",
        "community-services-workflow-completion-qualification",
        "document-signing",
        "input-sequences",
        "input-sequences-1",
        "intake",
        "kleene-plus",
        "qualification",
        "qualification-workflow",
        "startup-loadable",
        "workflow",
        "workflow-completion",
        "workflow-completion-monitor"
      ],
      "sequenceCount": 3,
      "populationFocus": "Community service enrollees requiring both qualification verification and signed agreements before service delivery can begin; organizations with multi-step onboarding workflows",
      "sensorNormalization": {
        "signing_signal_norm": "0.0=[1,0,0,0] SIGNING_BLOCKED from DocSigning (bit 438), 0.5=[0,0,1,0] PARTIAL_SIGNING (bit 440), 1.0=[0,0,0,1] SIGNING_COMPLETE (bit 441)",
        "qualification_signal_norm": "0.0=[1,0,0,0] QUALIFICATION_FAILED from QualVerification (bit 442), 0.5=[0,1,0,0] REVERIFICATION_REQUIRED (bit 443), 1.0=[0,0,0,1] FULLY_QUALIFIED (bit 445)",
        "workflow_age_norm": "0.0=workflow open >45 days without completion (stale; client likely disengaged), 0.5=workflow open 15–45 days (active but aging), 1.0=workflow open <15 days (fresh; on-track for timely completion)",
        "completion_likelihood_norm": "0.0=client unreachable; documents not returned; no recent activity, 0.5=partial progress; some items completed; client intermittently responsive, 1.0=active engagement; all steps progressing; completion imminent"
      },
      "upstreamMachines": [
        "DocumentSigningWorkflowMonitor (output [960:964])",
        "QualificationVerificationMonitor (output [964:968])"
      ],
      "tagging": {
