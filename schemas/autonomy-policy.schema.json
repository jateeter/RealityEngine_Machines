{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://realityengine.example.org/schemas/autonomy-policy-1.0.0.json",
  "title": "RealityEngine Agent Autonomy Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode",
    "stage",
    "writeBackType",
    "canWriteBack",
    "canStageActions",
    "canExecuteActions",
    "requiresHumanApproval",
    "requiresRunbook",
    "blockedWhenRag"
  ],
  "properties": {
    "mode": {
      "enum": ["observe", "advise", "supervised-act", "automated-act"]
    },
    "stage": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "writeBackType": {
      "enum": ["none", "pe-sensor", "pe-domain-vector"]
    },
    "canWriteBack": { "type": "boolean" },
    "canStageActions": { "type": "boolean" },
    "canExecuteActions": { "type": "boolean" },
    "requiresHumanApproval": { "type": "boolean" },
    "requiresRunbook": { "type": "boolean" },
    "blockedWhenRag": {
      "type": "array",
      "items": { "enum": ["GREEN", "AMBER", "RED"] },
      "uniqueItems": true
    },
    "rollbackRequired": { "type": "boolean" }
  }
}
