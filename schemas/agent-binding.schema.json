{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://realityengine.example.org/schemas/agent-binding-1.0.0.json",
  "title": "RealityEngine Machine Agent Binding",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent", "mode", "trigger", "allowedActions", "writeBack", "riskControls", "autonomyPolicy"],
  "properties": {
    "agent": {
      "type": "string",
      "minLength": 1,
      "description": "localAIStack agent id that should receive CES trigger envelopes."
    },
    "mode": {
      "type": "string",
      "enum": ["observe", "advise", "supervised-act", "automated-act"]
    },
    "trigger": {
      "type": "string",
      "minLength": 1,
      "description": "Named hook advertised by the target agent."
    },
    "allowedActions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "writeBack": {
      "$ref": "localai-writeback.schema.json"
    },
    "autonomyPolicy": {
      "$ref": "autonomy-policy.schema.json"
    },
    "riskControls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiresHumanApproval", "requiresRunbook", "maxAutonomy", "blockedWhenRag"],
      "properties": {
        "requiresHumanApproval": { "type": "boolean" },
        "requiresRunbook": { "type": "boolean" },
        "maxAutonomy": {
          "type": "string",
          "enum": ["observe", "advise", "supervised-act", "automated-act"]
        },
        "blockedWhenRag": {
          "type": "array",
          "items": { "type": "string", "enum": ["GREEN", "AMBER", "RED"] }
        }
      }
    }
  }
}
