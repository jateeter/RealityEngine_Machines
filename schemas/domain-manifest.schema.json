{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://realityengine.example.org/schemas/domain-manifest-1.0.0.json",
  "title": "RealityEngine Domain Manifest",
  "type": "object",
  "required": ["schemaVersion", "purpose", "domains"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "purpose": { "type": "string", "minLength": 1 },
    "domains": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "displayName",
          "status",
          "description",
          "codePrefixes",
          "defaultAutonomy",
          "requiredMachineClasses",
          "defaultAgentFamilies",
          "currentMachineCount",
          "sourceDataDefault",
          "peIngestPattern",
          "agentWorkflow"
        ],
        "properties": {
          "displayName": { "type": "string", "minLength": 1 },
          "status": { "enum": ["accepted", "experimental", "deprecated"] },
          "description": { "type": "string", "minLength": 1 },
          "codePrefixes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "defaultAutonomy": {
            "enum": ["observe", "advise", "supervised-act", "automated-act"]
          },
          "requiredMachineClasses": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "machine-class-1.0.0.json" }
          },
          "defaultAgentFamilies": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "currentMachineCount": { "type": "integer", "minimum": 0 },
          "sourceDataDefault": { "type": "string", "minLength": 1 },
          "peIngestPattern": { "type": "string", "minLength": 1 },
          "agentWorkflow": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
