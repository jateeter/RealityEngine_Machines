{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://realityengine.example.org/schemas/localai-completion-writeback-1.0.0.json",
  "title": "localAIStack Completion Write-Back Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["provider", "agent", "sensorId", "region", "values", "ttlMs", "triggerPush", "compactPush"],
  "properties": {
    "provider": { "type": "string", "minLength": 1 },
    "agent": { "type": "string", "minLength": 1 },
    "completionId": { "type": "string" },
    "correlationId": { "type": "string" },
    "envelopeId": { "type": "string" },
    "sensorId": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": ["offset", "length"],
      "properties": {
        "offset": { "type": "integer", "minimum": 0 },
        "length": { "type": "integer", "minimum": 1 }
      }
    },
    "sourceMapping": {
      "type": "object",
      "additionalProperties": true
    },
    "values": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "number" }
    },
    "ttlMs": { "type": "integer", "minimum": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "triggerPush": { "type": "boolean" },
    "compactPush": { "type": "boolean" }
  }
}
