{
  "name": "reality-engine-machines",
  "version": "1.0.0",
  "description": "Machine corpus (skills) and system-wide tests for the RealityEngine universe",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npx playwright test",
    "test:e2e": "npx playwright test tests/e2e",
    "test:smoke": "npx playwright test tests/smoke",
    "test:integration": "npx playwright test tests/integration",
    "test:report": "npx playwright show-report e2e-report",
    "validate": "bash scripts/validate-corpus.sh",
    "seed": "bash scripts/seed-machines.sh",
    "seed:local": "bash scripts/seed-machines.sh https://localhost:3000"
  },
  "engines": {
    "node": ">=25.5.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "typescript": "^5.4.0"
  }
}
